{
  "name": "@wuwenbin/server",
  "version": "0.0.1",
  "private": true,
  "homepage": "https://api.tongdelove.com",
  "scripts": {
    "-prebuild": "rimraf dist && pnpm run generate",
    "api": "pnpm swagger-to-graphql --swagger-schema=./api-docs.json > api.schema.graphql",
    "build": "nest build",
    "compose:down": "docker-compose down --volumes",
    "compose:up": "docker-compose up -d",
    "crud": "pnpm nest g resource",
    "db:clean": "ts-node scripts/clean.ts",
    "db:init": "run-s \"db:migrate-save -- --name 'initial version'\" db:migrate-up seed",
    "db:migrate-save": "prisma migrate dev",
    "db:migrate-up": "prisma migrate deploy",
    "dev": "nest start --watch",
    "docker:build": "docker build .",
    "docker:db": "docker-compose -f docker-compose.db.yml up -d",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "generate": "pnpm prisma generate --schema=./prisma/schema.prisma",
    "generate:database": "pnpm prisma migrate dev --name init",
    "i": "pnpm --only=prod",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "nest": "nest",
    "prettier": "prettier --write --cache .",
    "prettier-diff": "git diff --name-only | grep '^clients/web/' | sed 's|^clients/web/||' | xargs prettier --write",
    "prisma:generate": "prisma generate",
    "pull": "pnpm prisma db pull",
    "push": "pnpm prisma db push",
    "seed": "pnpm prisma db seed",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:prod": "NODE_ENV=production node dist/src/main",
    "studio": "pnpm prisma studio"
  },
