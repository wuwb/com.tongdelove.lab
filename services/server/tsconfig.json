{
  "extends": "@tongdelove/typescript-config/base.json",
  "compilerOptions": {
    "allowUnreachableCode": false,
    "noFallthroughCasesInSwitch": true,
    "skipDefaultLibCheck": true,
    "module": "commonjs",
    "declaration": true,
    "strictPropertyInitialization": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2022",
    "outDir": "./dist",
    "noLib": false,
    "rootDir": ".",
    "baseUrl": ".",
    "types": ["node", "reflect-metadata", "Multer"],
    // https://stackoverflow.com/questions/61687679/nest-js-build-does-does-not-generate-the-dist-folder
    "noEmit": false,
    "noEmitOnError": false,
    "noEmitHelpers": true,
    "incremental": false, // 避免打包失败
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    // 支持
    "resolveJsonModule": true,
    // 允许
    "allowUnusedLabels": true,
    // 不允许
    "noImplicitAny": false,
    "noImplicitOverride": false,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "moduleResolution": "node",
    "noUnusedParameters": false,
    "forceConsistentCasingInFileNames": true, // 强制在文件名中使用一致的大小写，默认为 true
    "noImplicitReturns": false,
    "noUnusedLocals": false,
    "allowJs": true,
    "strict": true,
    "paths": {
      "@/scripts/*": ["scripts/*"],
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": ["**/*", "src/**/*", "tests/**/*", "scripts/**/*"],
  "exclude": [
    "node_modules"
  ],
  "ts-node": {
    "esm": true,
    // Do not forget to `npm i -D tsconfig-paths`
    "require": [
      "tsconfig-paths/register"
    ]
  }
}
