  status            Int?              @default(0) @map(name: "user_status") // 状态
  displayName       String?           @default("") @map(name: "display_ame") // 显示名称
  resetKey          String?           @map(name: "user_reset_key") // 重置密码
  // 通过代码保证唯一性
  phone             String?           @default("") @map(name: "user_phone") // 手机号
  spam              Int?              @default(0) // 是否是垃圾用户
  firstName         String?           @default("") @map(name: "first_name") // 名
  lastName          String?           @default("") @map(name: "last_name") // 姓
  age               Int? // 年龄
  platform          Int?              @default(0) // 平台
