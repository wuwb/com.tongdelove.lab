  postStatus          String    @default("") @map(name: "post_status") @db.VarChar(255) // 文章状态，publish，draft
  commentStatus       String    @default("") @map(name: "comment_status") @db.VarChar(255)
  pingStatus          String    @default("") @map(name: "ping_status") @db.VarChar(255)
  postPassword        String    @default("") @map(name: "post_password") @db.VarChar(255)
  postName            String    @unique @default("") @map(name: "post_name") @db.VarChar(200) // slug
  toPing              String    @default("") @map(name: "to_ping") @db.VarChar(255)
  pinged              String    @default("") @map(name: "pinged") @db.VarChar(255)
  postModified        DateTime  @updatedAt @map(name: "post_modified")
  postModifiedGmt     DateTime  @map(name: "post_modified_gmt")
  postContentFiltered Int       @map(name: "post_content_filtered") @db.SmallInt
  postParent          Int       @map(name: "post_parent") @db.SmallInt
  guid                String    @default("") @db.VarChar(255)
  menuOrder           Int       @map(name: "menu_order") @db.SmallInt
  postType            String    @default("") @map(name: "post_type") @db.VarChar(255)
  postMimeType        String    @default("") @map(name: "post_mime_type") @db.VarChar(255)
  commentCount        Int       @map(name: "comment_count") @db.SmallInt
  viewCount           Int       @default(0) @map(name: "view_count") @db.SmallInt
  likesCount          Int       @map(name: "likes_count") @db.SmallInt
  user                User      @relation(fields: [userId], references: [id])
  userId              String    @default("") @map(name: "user_id")
  createdAt           DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
  updatedAt           DateTime  @updatedAt @map(name: "updated_at") @db.Timestamp(6)
  isDeleted           Boolean   @default(false) @map(name: "is_deleted") // 是否删除
