// article

enum ArticleStatus {
  Verifying // = 1, // 审核中
  VerifySuccess // = 2, // 审核通过
  VerifyFail // = 3, // 审核未通过
}

enum ArticleContentType {
  Markdown // = 1,
  HTML // = 2,
}

model Article {
  id              String             @id @default(cuid())
  lastCommentAt   DateTime           @map(name: "last_comment_at")
  name            String             @db.VarChar(200)
  browseCount     Int                @map(name: "browse_count")
  commentCount    Int                @map(name: "comment_count")
  rootCommentCont Int                @map(name: "root_comment_count")
  likedCount      Int                @map(name: "liked_count")
  wordCount       Int                @map(name: "word_count")
  hot             Int
  status          ArticleStatus
  content         String             @db.Text
  htmlContent     String             @db.Text
  summary         String             @db.VarChar(500)
  coverURL        String             @db.VarChar(500)
  contentType     ArticleContentType @map(name: "content_type")
  categories      Category[]
  tags            Tag[]
  collections     Collection[]
  comments        Comment[]
  userId          String             @map(name: "user_id")
  user            User               @relation(fields: [userId], references: [id])
  createdAt       DateTime?          @default(now()) @map(name: "created_at") @db.Timestamp(6)
  updatedAt       DateTime           @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
  isDeleted       Boolean            @default(false) @map(name: "is_deleted") // 是否删除

  @@map(name: "article")
}

