model Poem {
  id        Int            @id @default(autoincrement())
  slug      String         @unique
  title     String         @db.VarChar(255)
  content   String         @db.Text
  locale    String?        @db.VarChar(5)
  keywords  PoemKeywords[]
  author    String         @db.VarChar(120)
  link      String?        @db.VarChar(255)
  image     String?        @db.VarChar(255)
  createdAt DateTime       @default(now()) @map(name: "created_at")
  updatedAt DateTime       @updatedAt @map(name: "updated_at")

  @@map(name: "poem")
}

model PoemKeywords {
  id        Int      @id @default(autoincrement())
  poem      Poem     @relation(fields: [poemId], references: [id], onDelete: Cascade)
  poemId    Int      @map(name: "poem_id")
  keyword   Keyword  @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  keywordId String   @map(name: "keyword_id")
  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@unique([poemId, keywordId])
  @@map(name: "poem_keywords")
}

model Keyword {
  id        String         @id @default(cuid())
  keyword   String         @default("") @db.VarChar(127)
  url       String         @default("") @db.VarChar(255)
  isHot     Int
  isDefault Int
  sortOrder Int
  createdAt DateTime?      @default(now()) @map(name: "created_at") @db.Timestamp(6)
  updatedAt DateTime       @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
  isDelete  Boolean        @default(false) @map(name: "is_delete")
  name      String         @unique @db.VarChar(120)
  locale    String?        @db.VarChar(5)
  poems     PoemKeywords[]

  @@map(name: "keyword")
}

enum UserPermissionRole {
  ADMIN @map("admin")
  USER  @map("user")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map(name: "session_token") @db.Text
  userId       String   @unique @map(name: "user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map(name: "session")
}

model LinkCategory {
  id              Int               @id @default(autoincrement())
  icon            String
  title           String
  description     String
  order           Int
  rank            Int?
  createdAt       DateTime          @default(now()) @map(name: "created_at")
  updatedAt       DateTime          @default(now()) @map(name: "updated_at")
  links           Link[]
  LinkSubCategory LinkSubCategory[]

  parentId        Int?           @map("parent_id")
  parentCategory  LinkCategory?  @relation("ChildCategories", fields: [parentId], references: [id])
  childCategories LinkCategory[] @relation("ChildCategories")
}

model LinkSubCategory {
  id          Int          @id @default(autoincrement())
  icon        String
  title       String
  description String
  order       Int
  createdAt   DateTime     @default(now()) @map(name: "created_at")
  updatedAt   DateTime     @default(now()) @map(name: "updated_at")
  links       Link[]
  categoryId  Int
  category    LinkCategory @relation(fields: [categoryId], references: [id])
}

model Link {
  id            String           @id @default(cuid())
  icon          String?
  url           String
  title         String
  description   String?
  public        Boolean          @default(true)
  status        Int              @default(1)
  createdAt     DateTime         @default(now()) @map(name: "created_at")
  updatedAt     DateTime         @map(name: "updated_at")
  catagoryId    Int?
  catagory      LinkCategory?    @relation(fields: [catagoryId], references: [id])
  subCategoryId Int?
  subCategory   LinkSubCategory? @relation(fields: [subCategoryId], references: [id])
}

// 开始
// ----------------------------------------------
// system

model Menu {
  id        String  @id @default(cuid())
  name      String  @db.VarChar(50) // 菜单名称
  type      String  @default("") // 菜单类型（M目录 C菜单 F按钮）
  order     Int // 顺序
  path      String? // 路由地址
  component String? @db.VarChar(255) // 组件路径
  query     String? @db.VarChar(255) // 路由参数
  isFrame   Int     @default(1) @map(name: "is_frame") // 是否为外链（0是 1否）
  isCache   Int     @default(0) @map(name: "is_cache") // 是否缓存（0缓存 1不缓存）
  visible   Int?    @default(0) // 菜单状态（0显示 1隐藏）
  status    Int?    @default(0) // 菜单状态（0正常 1停用）
  perms     String? @db.VarChar(100) // 权限标识
  icon      String? @db.VarChar(100)
  children  Menu[]  @relation("menu")
  parent    Menu?   @relation("menu", fields: [parentId], references: [id])
  roles     Role[]
  parentId  String?
}

model SysConfig {
  id    String @id @default(cuid())
  name  String // 参数名
  key   String // 参数键名
  value String // 参数键值
  type  Int    @default(0) // 系统内置（1是 0否)

  @@map(name: "sys_config")
}

// ----------------------------------------------
// e-commerce

model Carousel {
  id          String    @id @default(cuid())
  imgurl      String    @default("") @db.Text
  title       String    @default("") @db.VarChar(63)
  url         String    @default("") @db.VarChar(255)
  description String    @default("") @db.VarChar(255)
  status      String    @default("") @db.VarChar(255)
  remark      String    @default("") @db.VarChar(255)
  type        Int
  country     String    @default("")
  startAt     DateTime  @map(name: "start_at")
  endAt       DateTime  @map(name: "end_at")
  isAudit     Int       @default(0) @db.SmallInt
  sort        Int       @default(0) @db.SmallInt // 排序
  createdAt   DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
  isDeleted   Boolean   @default(false) @map(name: "is_deleted") // 是否删除
}

// 产品
model Product {
  id            String       @id @default(cuid())
  goods_sn      String       @db.VarChar(63)
  productSku    ProductSku[]
  createdAt     DateTime?    @default(now()) @map(name: "created_at") @db.Timestamp(6)
  updatedAt     DateTime     @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
  isDeleted     Boolean      @default(false) @map(name: "is_deleted") // 是否删除
  deleted       Boolean      @default(false)
  slug          String       @db.VarChar(100)
  title         String?      @default("") @db.VarChar(100) // 标题
  subTitle      String       @default("") @map(name: "sub_title") @db.VarChar(100) // 副标题
  keywords      String       @db.VarChar(255)
  brief         String       @db.VarChar(255)
  description   String?      @default("") @db.VarChar(255) // 描述
  code          String       @db.VarChar(63) // 商品编码
  flag          Int          @db.SmallInt // 二进制打标
  brand_id      String       @default("")
  category_id   String       @default("") // 分类
  custom_id     String // 关联其他自定义系统的数据
  summary       String       @default("") @db.VarChar(255) // 商品简介
  content       String       @db.Text // 商品详情，富文本测试
  is_on_sale    Int          @default(1) @db.SmallInt // 是否上架
  sort          Int          @default(100) @db.SmallInt // 排序
  image         String       @db.VarChar(255) // 主图片
  pic_url       String       @default("") @db.VarChar(255) // 图片，json 格式，可扩展
  share_url     String       @default("") @db.VarChar(255) // 分享链接
  is_new        Int          @default(0) @db.SmallInt // 是否新品
  is_hot        Int          @default(0) @db.SmallInt // 是否人气
  unit          String       @default("件") @db.VarChar(31) // 单位
  counter_price Decimal      @default(0.0000) @db.Decimal(10, 4) // 专柜价格
  retail_price  Decimal      @default(0.0000) @db.Decimal(10, 4) // 零售价格
  detail        String       @db.Text
  price         Decimal      @db.Decimal(10, 4)
  sku           String       @db.VarChar(100)
  published     Boolean      @default(false)
  published_at  DateTime     @db.Timestamp(6)
  biz_type      Int          @db.SmallInt
  Post          Post?        @relation(fields: [postId], references: [id])
  postId        String?
  Brand         Brand?       @relation(fields: [brandId], references: [id])
  brandId       String?

  @@map(name: "product")
}

model ProductHistory {
  id String @id @default(cuid())

  @@map(name: "product_history")
}

model ProductSnapshot {
  id String @id @default(cuid())

  @@map(name: "product_snapshot")
}

model ProductCategory {
  id          String @id @default(cuid())
  type        Int    @default(0) @db.SmallInt // 类型，默认为 0 是产品分类，1 是文章分类
  title       String @db.VarChar(63)
  keywords    String @default("") @db.VarChar(1023)
  description String @default("") @db.VarChar(255)
  pid         Int    @db.SmallInt
  status      Int    @default(1) @db.SmallInt // 状态 1 启用，0禁用
  icons       String @default("") @db.VarChar(255)
  picture     String @default("") @db.VarChar(255)
  level       String @default("") @db.VarChar(255)
  sort        Int    @default(50) @db.SmallInt

  @@map(name: "product_category")
}

// 收藏
model Collect {
  id        String    @id @default(cuid())
  createdAt DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
  updatedAt DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
  isDeleted Boolean   @default(false) @map(name: "is_deleted") // 是否删除
  user_id   Int       @default(0) @db.SmallInt
  value_id  Int       @default(0) @db.SmallInt
  type      Int       @default(0) @db.SmallInt

  @@map(name: "collect")
}

model ProductImage {
  id String @id @default(cuid())

  @@map(name: "product_image")
}

model ProductAttrKey {
  id         String @id @default(cuid())
  product_id Int    @default(0) @db.SmallInt
  title      String @db.VarChar(255) // 商品参数名称

  @@map("product_attr_key")
}

model ProductAttrValue {
  id          String    @id @default(cuid())
  createdAt   DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
  isDeleted   Boolean   @default(false) @map(name: "is_deleted") // 是否删除
  attr_key_id Int       @default(0) @db.SmallInt
  product_id  Int       @default(0) @db.SmallInt
  symbol      Int       @db.SmallInt // '属性编码'
  value       String    @db.VarChar(255) // 商品参数值

  @@map(name: "product_attr_value")
}

model ProductSku {
  id               String        @id @default(cuid())
  product          Product       @relation(fields: [productId], references: [id]) // 一个订单详情有一个订单
  productId        String        @map(name: "product_id")
  orderDetail      OrderDetail[]
  attr_symbol_path String        @db.VarChar(255)
  price            Decimal       @default(0.0000) @db.Decimal(10, 4)
  stock            Int           @db.SmallInt

  @@map(name: "product_sku")
}

