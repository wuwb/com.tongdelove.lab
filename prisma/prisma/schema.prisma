  user         User                     @relation(fields: [userId], references: [id])
  bookId       String
  book         HandBook                 @relation(fields: [bookId], references: [id])
  comments     HandBookChapterComment[]
  createdAt    DateTime?                @default(now()) @map(name: "created_at") @db.Timestamp(6)
  updatedAt    DateTime                 @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
  isDeleted    Boolean                  @default(false) @map(name: "is_deleted") // 是否删除
}

// hand book category

model HandBookChapterComment {
  id                String          @id @default(cuid())
  name              String          @db.VarChar(200)
  sequence          Int
  HandBookChapterId String
  HandBookChapter   HandBookChapter @relation(fields: [HandBookChapterId], references: [id])
  createdAt         DateTime?       @default(now()) @map(name: "created_at") @db.Timestamp(6)
  updatedAt         DateTime        @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
  isDeleted         Boolean         @default(false) @map(name: "is_deleted") // 是否删除
}

model Analyze {
  id        String   @id @default(cuid())
  ip        String
  ua        String
  path      String
  timestamp DateTime

  @@map(name: "analyze")
}

