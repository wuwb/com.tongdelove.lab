// 评价，根据类型分为，文章评价，商品评价，专题评价等
model Comment {
  id                 String        @id @default(cuid())
  commentPostId      String        @unique @default("") @map(name: "comment_post_id")
  commentAuthor      String        @default("") @map(name: "comment_author") @db.VarChar(255)
  commentAuthorEmail String        @default("") @map(name: "comment_author_email") @db.VarChar(255)
  commentAuthorUrl   String        @default("") @map(name: "comment_author_url") @db.VarChar(255)
  commentAuthorIp    String        @default("") @map(name: "comment_author_ip") @db.VarChar(255)
  commentDate        DateTime      @map(name: "comment_date") @db.Timestamp(6)
  commentDateGmt     DateTime      @map(name: "comment_date_gmt") @db.Timestamp(6)
  commentkarma       Int           @map(name: "comment_karma") @db.SmallInt
  commentApproved    Int           @map(name: "comment_approved") @db.SmallInt
  commentAgent       String        @default("") @map(name: "comment_agent") @db.VarChar(255)
  commentType        String        @default("") @map(name: "comment_type") @db.VarChar(255) // comment, pingback, trackback
  commentParent      Int           @map(name: "comment_parent") @db.SmallInt
  userId             String        @unique @default("") @map(name: "user_id")
  type               Int           @default(0) @db.SmallInt // 评论类型，如果type=0，则是商品评论；如果是type=1，则是专题评论；
  replay             String        @default("") @db.VarChar(511) // 回复信息
  hasPicture         Int           @default(0) @map(name: "has_picture") @db.SmallInt // 是否有图片
  picUrls            String        @default("") @map(name: "picUrls") @db.VarChar(1023) // 图片地址列表，采用JSON数组格式
  star               Int           @default(0) @db.SmallInt
  valueId            String        @unique @default("") @map(name: "value_id")
  content            String        @default("") @db.Text
  htmlContent        String        @default("") @db.Text
  adminContent       String        @default("") @map(name: "admin_content") @db.VarChar(1023)
  user               User          @relation(fields: [userId], references: [id])
  status             CommentStatus
  createdAt          DateTime?     @default(now()) @map(name: "created_at") @db.Timestamp(6)
  updatedAt          DateTime      @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
  isDeleted          Boolean       @default(false) @map(name: "is_deleted") // 是否删除
  parentId           String
  rootId             String
  latest             String // 最近两条子评论
  commentCount       Int // 子评论数量
  likedCount         Int // 点赞数量
  sourceId           Int
  Article            Article?      @relation(fields: [articleId], references: [id])
  articleId          String?

  @@map(name: "comment")
}

