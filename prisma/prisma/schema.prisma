// 优惠券
model Coupon {
  id          String    @id @default(cuid())
  createdAt   DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
  isDeleted   Boolean   @default(false) @map(name: "is_deleted") // 是否删除
  title       String    @default("") @db.VarChar(255) // 优惠券名称
  description String    @default("") @db.VarChar(255) // 优惠券介绍，通常是显示优惠券使用限制文字
  code        String    @default("") @db.VarChar(255) // 优惠券兑换码
  discount    Decimal   @default(0.0000) @db.Decimal(10, 4) // 折扣，优惠金额
  type        Int       @db.SmallInt // 类型
  limit       Int       @default(1) @db.SmallInt // 用户领券限制数量，如果是0，则是不限制；默认是1，限领一张
  min         Decimal   @db.Decimal(10, 4) // 最少消费金额才能使用优惠券
  condition   Int       @db.SmallInt // 使用条件
  goodsType   Int       @default(0) @map(name: "goods_type") @db.SmallInt // 商品限制类型，如果0则全商品，如果是1则是类目限制，如果是2则是商品限制
  goodsValue  String    @default("") @map(name: "goods_value") @db.VarChar(1023)
  total       Int       @default(0) @db.SmallInt // 数量，0 表示无限
  usedCount   Int       @map(name: "userd_count") @db.SmallInt // 使用数量
  timeType    Int       @default(0) @map(name: "time_type") @db.SmallInt // 有效时间限制，如果是0，则基于领取时间的有效天数days；如果是1，则start_time和end_time是优惠券有效期
  status      Int       @default(0) @db.SmallInt // 优惠券状态，如果是0则是正常可用；如果是1则是过期; 如果是2则是下架
  expiration  DateTime
  days        Int       @default(0) @db.SmallInt // 优惠券有效期天数
  startAt     DateTime  @map(name: "start_at")
  endAt       DateTime  @map(name: "end_at")
  tag         String    @default("") @db.VarChar(63)

  @@map(name: "coupon")
}

// 优惠券使用
model CouponUsed {
  id        String    @id @default(cuid())
  createdAt DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
  updatedAt DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
  isDeleted Boolean   @default(false) @map(name: "is_deleted") // 是否删除
  couponId  String    @unique @default("") @map(name: "coupon_id") @db.VarChar(255) // 优惠券 ID
  userId    String    @unique @default("") @map(name: "user_id") @db.VarChar(255) // 用户 ID
  orderId   String    @unique @default("") @map(name: "order_id") @db.VarChar(255) // 订单 ID
  usedAt    DateTime  @map(name: "used_at") // 使用时间
  status    Int       @default(0) @db.SmallInt // 使用状态, 如果是0则未使用；如果是1则已使用；如果是2则已过期；如果是3则已经下架
  startAt   DateTime  @map(name: "start_at") // 有效期开始时间
  endAt     DateTime  @map(name: "end_at") // 有效期截至时间

  @@map(name: "coupon_used")
}

model Groupon {
  id            String    @id @default(cuid())
  createdAt     DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
  isDeleted     Boolean   @default(false) @map(name: "is_deleted") // 是否删除
  orderId       String    @unique @default("") @map(name: "order_id")
  grouponId     String    @unique @default("") @map(name: "groupon_id") // 如果是开团用户，则groupon_id是0；如果是参团用户，则groupon_id是团购活动ID
  rulesId       String    @unique @default("") @map(name: "rules_id") // 团购规则ID，关联litemall_groupon_rules表ID字段
  userId        String    @unique @default("") @map(name: "user_id") // 用户ID
  shareUrl      String    @default("") @map(name: "share_url") @db.VarChar(255) // 团购分享图片地址
  creatorUserId String    @unique @default("") @map(name: "creator_user_id") // 创建团购的用户ID
  creatorUserAt DateTime  @map(name: "creator_user_at") // 创建团购的时间
  status        Int       @default(0) @db.SmallInt // 团购活动状态，开团未支付则0，开团中则1，开团失败则2

  @@map(name: "groupon")
}

model GrouponRules {
  id             String   @id @default(cuid())
  goodsId        String   @unique @default("") @map(name: "goods_id") // 商品表的商品ID
  goodsName      String   @default("") @map(name: "goods_name") @db.VarChar(127) // 商品名称
  picUrl         String   @default("") @map(name: "pic_url") @db.VarChar(255)
  discount       Decimal  @db.Decimal(63, 0) // 优惠金额
  discountMember Int      @map(name: "discount_member") @db.SmallInt // 达到优惠条件的人数
  expireAt       DateTime @map(name: "expire_at") // 团购过期时间
  status         Int      @default(0) @db.SmallInt // 团购规则状态，正常上线则0，到期自动下线则1，管理手动下线则2

  @@map(name: "groupon_rules")
}

