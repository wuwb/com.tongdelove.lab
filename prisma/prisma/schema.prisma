  description String?   @db.VarChar(100) // 描述

  @@unique([actionName, isDeleted], map: "action_name_delete_at")
  @@unique([moduleName, isDeleted], map: "module_name_delete_at")
  @@map(name: "access")
}

// NextAuth.js Models
// NOTE: When using postgresql, mysql or sqlserver,
// uncomment the @db.Text annotations below
// @see https://next-auth.js.org/schemas/models
model Account {
  id                String    @id @default(cuid())
  userId            String    @unique @map(name: "user_id")
  type              String
  provider          String    @db.VarChar(63) // email、google
  providerAccountId String    @unique @map(name: "provider_account_id")
  refreshToken      String?   @map(name: "refresh_token") @db.Text
  accessToken       String?   @map(name: "access_token") @db.Text
  expiresAt         Int?      @map(name: "expires_at")
  tokenType         String?   @map(name: "token_type")
  scope             String?
  idToken           String?   @map(name: "id_token") @db.Text
  sessionState      String?   @map(name: "session_state")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
  updatedAt         DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
  isDeleted         Boolean   @default(false) @map(name: "is_deleted") // 是否删除

  // for github @see https://next-auth.js.org/providers/github
  refresh_token_expires_in Int?

  @@unique([provider, providerAccountId])
  @@map(name: "account")
}

model AccountLastLogin {
  id               String    @id @default(cuid())
  accountId        String    @map(name: "account_id")
  lastLoginIp      String?   @default("") @map(name: "last_login_ip") @db.VarChar(63)
  lastLoginAddress String?   @default("") @map(name: "last_login_address") @db.VarChar(100)
  lastLoginTime    DateTime  @default(now()) @map(name: "last_login_time") @db.Timestamp(0)
