model Access {
  id          String    @id @default(cuid())
  createdAt   DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
  isDeleted   Boolean   @default(false) @map(name: "is_deleted") // 是否删除
  moduleName  String?   @map("module_name") @db.VarChar(50) // 模块名称
  type        Int? // 类型,1:表示模块,2:表示菜单,3:表示接口(API)
  actionName  String?   @map("action_name") @db.VarChar(100) // 操作名称
  apiName     String?   @map("api_name") @db.VarChar(100) // 接口名称
  icon        String?   @db.VarChar(100) // 小图标
  url         String?   @db.VarChar(100) // url地址
