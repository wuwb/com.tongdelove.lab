{
  "extends": "@tongdelove/tsconfig/base.json",
  "compilerOptions": {
    "baseUrl": "./src",
    "module": "ES2020",
    "noEmit": false,
    "incremental": true,
    "paths": {},
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "composite": true
  },
  "include": [
    ".eslintrc.*",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    "**/*.js",
    "**/*.cjs",
    "**/*.mjs",
    "**/*.jsx",
    "**/*.json"
  ],
  "exclude": [
    "**/node_modules",
    "**/.*/*",
    "dist"
  ]
}
