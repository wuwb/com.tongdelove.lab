{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "build:docker": "docker build -t nextjs-docker .",
    "start:docker": "docker run -p 3000:3000 nextjs-docker",
    "analyze": "BUNDLE_ANALYZE=both next build",
    "lint": "next lint",
    "lint:fix": "next lint --fix"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.7",
    "@emotion/react": "^11.8.2",
    "@emotion/styled": "^11.8.1",
    "@tailwindcss/typography": "^0.5.1",
    "antd": "^4.18.7",
    "axios": "^1.7.2",
    "axios-hooks": "^3.0.1",
    "classnames": "^2.3.1",
    "cookie": "^0.6.0",
    "dayjs": "^1.11.11",
    "enquire-js": "^0.2.1",
    "gray-matter": "^4.0.3",
    "i18next": "^22.4.10",
    "js-cookie": "^3.0.5",
    "konva": "^8.3.4",
    "lodash.debounce": "^4.0.8",
    "lodash.random": "^3.2.0",
    "lodash.throttle": "^4.1.1",
    "next": "14.2.4",
    "next-auth": "^4.24.7",
    "next-i18next": "^13.3.0",
    "next-seo": "^4.28.1",
    "next-transpile-modules": "^9.0.0",
