    "react-intl": "^5.24.6",
    "react-jss": "^10.9.0",
    "react-konva": "^18.2.10",
    "react-markdown": "^8.0.7",
    "react-scripts": "^3.4.1",
    "react-transition-group": "^4.4.2",
    "react-use": "^17.3.2",
    "remark": "^12.0.0",
    "remark-html": "^16.0.1",
    "swr": "^1.2.2",
    "wpapi": "^1.2.2"
  },
  "devDependencies": {
    "@storybook/react": "^7.6.17",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
