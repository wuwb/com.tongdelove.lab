{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "analyze": "BUNDLE_ANALYZE=both next build",
    "build": "next build",
    "build:docker": "docker build -t nextjs-docker .",
    "dev": "next dev",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "prettier": "prettier --write --cache .",
    "prettier-diff": "git diff --name-only | grep '^clients/web/' | sed 's|^clients/web/||' | xargs prettier --write",
    "start": "next start",
    "start:docker": "docker run -p 3000:3000 nextjs-docker"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint",
      "prettier --write",
      "git add"
    ],
    "**/*.{md,mdx,json}": [
      "prettier --write",
      "git add"
    ]
  },
  "dependencies": {
    "@ant-design/cssinjs": "^1.20.0",
    "@emotion/react": "^11.8.2",
    "@emotion/styled": "^11.8.1",
    "@tailwindcss/typography": "^0.5.1",
    "antd": "^5.19.3",
    "axios": "^1.7.2",
    "axios-hooks": "^3.0.1",
    "clsx": "^2.1.1",
    "cookie": "^0.6.0",
    "dayjs": "^1.11.12",
    "enquire-js": "^0.2.1",
    "gray-matter": "^4.0.3",
    "i18next": "^22.4.10",
    "js-cookie": "^3.0.5",
    "konva": "^8.3.4",
    "lodash-es": "^4.17.21",
    "lodash.debounce": "^4.0.8",
    "lodash.random": "^3.2.0",
    "lodash.throttle": "^4.1.1",
    "next": "14.2.5",
    "next-auth": "^4.24.7",
    "next-i18next": "^13.3.0",
    "next-seo": "^4.28.1",
    "next-transpile-modules": "^9.0.0",
    "nextjs-progressbar": "^0.0.16",
    "react": "18.3.1",
    "react-cookie": "^4.1.1",
    "react-dom": "18.3.1",
    "react-fast-marquee": "^1.6.5",
    "react-ga": "^3.1.2",
    "react-icons": "^4.10.1",
    "react-intl": "^5.24.6",
    "react-jss": "^10.9.0",
    "react-konva": "^18.2.10",
    "react-markdown": "^8.0.7",
    "react-transition-group": "^4.4.2",
    "react-use": "^17.5.1",
    "remark": "^12.0.0",
    "remark-html": "^16.0.1",
    "swr": "^1.2.2",
    "wpapi": "^1.2.2"
  },
  "devDependencies": {
    "@storybook/react": "^7.6.17",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@tongdelove/eslint-config": "workspace:^",
    "@tongdelove/typescript-config": "workspace:^",
    "@types/lodash.debounce": "^4.0.6",
    "@types/lodash.random": "^3.2.6",
    "@types/lodash.throttle": "^4.1.6",
    "@types/node": "^18.14.1",
    "@types/react": "18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-transition-group": "^4.4.4",
    "autoprefixer": "^10.4.19",
    "eslint-plugin-storybook": "^0.8.0",
    "eslint-plugin-testing-library": "^6.2.2",
    "next-compose-plugins": "^2.2.1",
    "next-plugin-antd-less": "^1.8.0",
    "postcss": "^8.4.39",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-import": "^14.0.2",
    "postcss-preset-env": "^7.0.1",
    "prettier-plugin-tailwindcss": "^0.4.1",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
