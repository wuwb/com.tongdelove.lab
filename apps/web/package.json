{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://www.printlake.com",
  "scripts": {
    "analyze": "BUNDLE_ANALYZE=both next build",
    "build": "next build",
    "build:docker": "docker build -t nextjs-docker .",
    "dev": "next dev",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "prettier": "prettier --write --cache .",
    "prettier-diff": "git diff --name-only | grep '^clients/web/' | sed 's|^clients/web/||' | xargs prettier --write",
    "start": "next start",
    "start:docker": "docker run -p 3000:3000 nextjs-docker"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint",
      "prettier --write",
      "git add"
    ],
    "**/*.{md,mdx,json}": [
      "prettier --write",
      "git add"
    ]
  },
  "dependencies": {
    "@ant-design/cssinjs": "1.23.0",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.14.0",
    "@libsql/client": "^0.14.0",
    "@next/third-parties": "^15.0.4",
    "@tailwindcss/typography": "^0.5.15",
    "@tongdelove/db": "workspace:^",
    "@tongdelove/design": "workspace:^",
    "@tongdelove/ui": "workspace:^",
    "axios": "^1.12.2",
    "axios-hooks": "^3.0.1",
    "clsx": "^2.1.1",
    "cookie": "^0.6.0",
    "dayjs": "^1.11.13",
    "enquire-js": "^0.2.1",
    "gray-matter": "^4.0.3",
    "i18next": "^22.4.10",
    "js-cookie": "^3.0.5",
    "konva": "^9.3.20",
    "lodash-es": "^4.17.21",
    "next": "14.2.5",
    "next-auth": "^4.24.11",
    "next-i18next": "^13.3.0",
    "next-seo": "^4.28.1",
    "next-themes": "^0.4.4",
    "next-transpile-modules": "^9.0.0",
    "nextjs-progressbar": "^0.0.16",
    "react": "^19.2.0",
    "react-cookie": "^4.1.1",
    "react-dom": "^19.2.0",
    "react-fast-marquee": "^1.6.5",
    "react-ga": "^3.1.2",
    "react-icons": "^4.10.1",
    "react-intl": "^5.24.6",
    "react-jss": "^10.9.0",
    "react-konva": "^18.2.10",
    "react-markdown": "^10.1.0",
    "react-transition-group": "^4.4.2",
    "react-use": "^17.5.1",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "swiper": "8.4.5",
    "swr": "^1.2.2",
    "wpapi": "^1.2.2"
  },
  "devDependencies": {
    "@builder.io/partytown": "^0.10.2",
    "@storybook/react": "^7.6.17",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@tongdelove/eslint-config": "workspace:^",
    "@tongdelove/typescript-config": "workspace:^",
    "@types/node": "24.10.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "^4.4.4",
    "autoprefixer": "^10.4.19",
    "eslint-plugin-storybook": "^0.8.0",
    "eslint-plugin-testing-library": "^6.2.2",
    "next-compose-plugins": "^2.2.1",
    "postcss": "^8.5.6",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-import": "^14.0.2",
    "postcss-preset-env": "^9.5.4",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "tailwindcss": "^4.1.11",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
