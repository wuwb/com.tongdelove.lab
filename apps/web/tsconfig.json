{
  "extends": "@tongdelove/typescript-config/nextjs.json",
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "noUnusedLocals": false,
    "noImplicitOverride": false,
    "paths": {
      "@/*": ["src/*"],
      "@tongdelove/design/*": ["../../packages/design/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "additional.d.ts",
    "**/*.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "next-env.d.ts",
    "**/*.cjs",
    "**/*.mjs",
    "scripts/*.mts",
    "deploymen/**/*",
    "scripts/**/*",
    ".eslintrc.js",
    "deployment/waitForPreview.js",
    "deployment/getDeploymentUrl.js",
    "next-sitemap.config.js",
    "vitest.config.mts"
  ],
  "exclude": [
    "node_modules",
    "./framework/bigcommerce",
    "./framework/shopify",
    "./framework/swell",
    "./framework/vendure",
    "./framework/saleor"
  ]
}
