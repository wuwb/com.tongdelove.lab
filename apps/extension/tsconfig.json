{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "target": "ES2017",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,

    "allowImportingTsExtensions": true,
    "allowJs": true,
    "jsx": "react-jsx",
    "types": ["chrome"],
    "lib": ["DOM", "dom.iterable", "ESNext", "WebWorker"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "exclude": ["node_modules", "src/entrypoints.inactive/**"]
}
