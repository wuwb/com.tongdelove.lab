{
  "name": "banxiang-temu-toolbox",
  "type": "module",
  "version": "0.2.3",
  "private": true,
  "description": "manifest.json description",
  "scripts": {
    "dev": "wxt",
    "build:dev": "wxt build --mode development",
    "build": "wxt build --mode production",
    "zip": "wxt zip",
    "compile": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --write --cache .",
    "postinstall": "wxt prepare",
    "gen:pdf": "tsx scripts/split-pdfs.ts",
    "gen:png": "tsx scripts/pdf-to-png.ts",
    "gen:map": "tsx scripts/generate-barcode-map.ts",
    "prepare": "[ -n \"$CI\" ] || lefthook install",
    "bump": "bumpp -y -q",
    "submit": "wxt submit",
    "submit:latest": "bun exec 'rm -rf .output'; wxt zip && wxt submit --chrome-zip .output/*.zip",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@orpc/client": "^1.11.2",
    "@orpc/server": "^1.11.2",
    "@orpc/tanstack-query": "^1.11.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.9",
    "@tongdelove/hooks": "workspace:*",
    "@tongdelove/schema": "workspace:*",
    "@tongdelove/typescript-config": "workspace:*",
    "@tongdelove/ui": "workspace:*",
    "@tongdelove/utils": "workspace:*",
    "@vlcn.io/crsqlite-wasm": "^0.16.0",
    "@wxt-dev/i18n": "^0.2.4",
    "axios": "^1.12.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "webext-dynamic-content-scripts": "^10.0.3",
    "webext-permission-toggle": "^6.0.1",
    "lucide-react": "^0.554.0",
    "@tanstack/react-router": "^1.139.10",
    "zustand": "^5.0.9",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "eslint-plugin-react": "^7.37.5",
    "@eslint/js": "^9.39.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "tailwindcss-animate": "^1.0.7",
    "@antfu/eslint-config": "^6.2.0",
    "@eslint-react/eslint-plugin": "^2.3.5",
    "@eslint/eslintrc": "^3.3.1",
    "@types/chrome": "^0.1.29",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20251115.1",
    "@wxt-dev/auto-icons": "^1.1.0",
    "@wxt-dev/module-react": "^1.1.5",
    "bumpp": "^10.3.1",
    "eslint": "^9.39.1",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "fs-extra": "^11.3.2",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdf-to-png-converter": "^3.11.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite-plugin-remove-console": "^2.2.0",
    "wxt": "^0.20.11",
    "tw-animate-css": "^1.4.0",
    "@tailwindcss/vite": "4.1.17",
    "@tanstack/router-plugin": "^1.139.10",
    "@tanstack/react-router-devtools": "^1.139.10",
    "@tanstack/react-query-devtools": "^5.91.1",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-config-prettier": "^10.1.8"
  }
}
