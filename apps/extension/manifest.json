{
  "manifest_version": 3,
  "name": "Hello World Extension",
  "description": "A complex Chrome extension",
  "version": "1.0",
  "action": {
    "default_popup": "dist/popup.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ]
}
