{
  "name": "lab",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm -r --filter lab... build && pnpm run build:repo",
    "build:repo": "next build && if [ \"$VERCEL_ENV\" = 'production' ]; then prisma migrate deploy; fi",
    "build-fast": "NEXT_BUILD_ENV_SENTRY_ENABLED=0 NEXT_BUILD_ENV_SOURCEMAPS=0 NEXT_BUILD_ENV_TYPECHECK=0 NEXT_BUILD_ENV_LINT=0 next build",
    "bundle-analyze": "ANALYZE=true NEXT_BUILD_ENV_SENTRY_ENABLED=1 NEXT_BUILD_ENV_SENTRY_UPLOAD_DRY_RUN=1 NEXT_BUILD_ENV_TYPECHECK=0 NEXT_BUILD_ENV_LINT=0 pnpm build",
    "check-dist": "es-check -v",
    "check-size": "size-limit --highlight-less",
    "clean": "rimraf ./.next ./out ./coverage ./tsconfig.tsbuildinfo ./node_modules/.cache",
    "dev": "next dev",
    "fix-all-files": "ESLINT_USE_FLAT_CONFIG=false eslint --config ./.eslintrc.cjs --fix --ext .ts,.tsx,.js,.jsx,.cjs,.mjs,.mdx,.graphql ./src",
    "flamegraph-home": "npx 0x --output-dir './.debug/flamegraph/{pid}.0x' --on-port 'autocannon http://localhost:$PORT --duration 20' -- node ../../node_modules/.bin/next start",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx,.cjs,.mjs,.mdx,.graphql --cache --cache-location ../../.cache/eslint/nextjs-app.eslintcache --resolve-plugins-relative-to . .",
    "start": "next start",
    "test": "cypress run --headless --browser chrome",
    "test-e2e": "E2E_WEBSERVER_MODE=BUILD_AND_START playwright test",
    "typecheck": "tsc --project ./tsconfig.json --noEmit",
    "lint2": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs,.mdx,.graphql --cache --cache-location ../../.cache/eslint/nextjs-app.eslintcache",
    "db:push": "prisma db push && cd ../../packages/schema && pnpm build",
    "db:studio": "prisma studio",
    "db:migrate:create": "prisma migrate dev --create-only",
    "postinstall": "prisma generate",
    "build-stats": "ANALYZE=true npm run build",
    "pm2-start": "pm2 start npm --name \"lab\" -- start",
    "export": "next build && next export",
    "lint-fix": "next lint --fix",
    "prettier": "prettier --write --cache .",
    "prettier-diff": "git diff --name-only | grep '^clients/web/' | sed 's|^clients/web/||' | xargs prettier --write",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "cypress": "cypress open",
    "script": "npx ts-node --esm",
    "analyze": "ANALYZE=true next build",
    "analyze:server": "BUNDLE_ANALYZE=server next build",
    "analyze:browser": "BUNDLE_ANALYZE=browser next build",
    "tsc-check": "tsc -v && tsc --noEmit",
    "build-types": "tsc --noEmit --pretty",
    "nuke": "rimraf .next && rimraf .next && rimraf pnpm-lock.yaml && rimraf node_modules && pnpm",
    "clear": "rimraf .next out",
    "versionup": "standard-version -r patch",
    "versionup:minor": "standard-version -r minor",
    "versionup:major": "standard-version -r major",
    "versionup:init": "standard-version --first-release"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not ie 11",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "Chrome 118",
      "last 1 chrome version",
      "last 1 edge version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
