    "directory": "apps/nextjs-app"
  },
  "scripts": {
    "build": "next build",
    "build2": "next build && if [ $VERCEL_ENV = 'production' ]; then prisma db push; fi",
    "build-fast": "cross-env NEXT_BUILD_ENV_SENTRY_ENABLED=0 NEXT_BUILD_ENV_SOURCEMAPS=0 NEXT_BUILD_ENV_TYPECHECK=0 NEXT_BUILD_ENV_LINT=0 next build",
    "bundle-analyze": "cross-env ANALYZE=true NEXT_BUILD_ENV_SENTRY_ENABLED=1 NEXT_BUILD_ENV_SENTRY_UPLOAD_DRY_RUN=1 NEXT_BUILD_ENV_TYPECHECK=0 NEXT_BUILD_ENV_LINT=0 pnpm build",
    "check-dist": "es-check -v",
    "check-size": "size-limit --highlight-less",
    "clean": "rimraf ./.next ./out ./coverage ./tsconfig.tsbuildinfo ./node_modules/.cache",
    "dev": "next",
    "fix-all-files": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs,.mdx,.graphql --fix",
    "flamegraph-home": "npx 0x --output-dir './.debug/flamegraph/{pid}.0x' --on-port 'autocannon http://localhost:$PORT --duration 20' -- node ../../node_modules/.bin/next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs,.mdx,.graphql --cache --cache-location ../../.cache/eslint/nextjs-app.eslintcache",
    "start": "next start",
    "test": "cypress run --headless --browser chrome",
    "test-e2e": "cross-env E2E_WEBSERVER_MODE=BUILD_AND_START playwright test",
    "test-unit": "vitest run",
    "test-unit-watch": "vitest watch --ui",
    "typecheck": "tsc --project ./tsconfig.json --noEmit",
    "lint2": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs,.mdx,.graphql --cache --cache-location ../../.cache/eslint/nextjs-app.eslintcache",
    "db:push": "prisma db push",
    "build-stats": "ANALYZE=true npm run build",
    "build-prod": "run-s clean build export",
    "pm2-start": "pm2 start npm --name \"lab\" -- start",
    "export": "next build && next export",
    "lint-fix": "next lint --fix",
    "format": "prettier --write src/**/*.ts{,x}",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "cypress": "cypress open",
    "script": "npx ts-node --esm",
    "analyze": "cross-env ANALYZE=true next build",
    "analyze:server": "cross-env BUNDLE_ANALYZE=server next build",
    "analyze:browser": "cross-env BUNDLE_ANALYZE=browser next build",
    "tsc-check": "tsc -v && tsc --noEmit",
    "build-types": "tsc --noEmit --pretty",
    "nuke": "rimraf .next && rimraf .next && rimraf pnpm-lock.yaml && rimraf node_modules && pnpm",
    "clear": "rimraf .next out",
    "versionup": "standard-version -r patch",
    "versionup:minor": "standard-version -r minor",
    "versionup:major": "standard-version -r major",
    "versionup:init": "standard-version --first-release"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not ie 11",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version"
    ]
  },
