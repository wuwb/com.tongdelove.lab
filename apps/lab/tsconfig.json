{
  "extends": "@tongdelove/typescript-config/nextjs.json",
  "compilerOptions": {
    "target": "ES2017",
    "module": "esnext",
    "jsx": "react-jsx",
    /* Base Options: */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    /* Strictness */
    "strict": true, // trpc required
    "noUncheckedIndexedAccess": true,
    "checkJs": true,
    /* Bundled projects */
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
      "WebWorker"
      // "scripthost"
    ],
    "outDir": "dist",
    "noEmit": true,
    "moduleResolution": "Bundler", // node
    "importHelpers": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    /* Path Aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/public/*": ["public/*"],
      "@tongdelove/design/*": ["../../packages/design/src/*"],
      "@tongdelove/ui/*": ["../../packages/ui/src/*"]
    },
    "tsBuildInfoFile": "node_modules/.cache/tsbuildinfo.json",
    "strictNullChecks": true, // trpc required, need to be true
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    // custom
    "removeComments": true,
    "preserveConstEnums": true,
    "alwaysStrict": false,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "noImplicitThis": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "allowUnreachableCode": false,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "declarationMap": true,
    "preserveSymlinks": false, // set false or shadcn-ui broken
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "strictPropertyInitialization": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "composite": true,
    "types": ["node"],
    "noErrorTruncation": true,
    "allowImportingTsExtensions": false,
    "downlevelIteration": true
  },
  "include": [
    "next.config.ts",
    ".eslintrc.*",
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    "**/*.js",
    "**/*.cjs",
    "**/*.mjs",
    "**/*.jsx",
    "**/*.json",
    ".next/types/**/*.ts",
    "next-i18next.config.js",
    "scripts/*.mts",
    "../../prettier.config.js",
    "scripts/*.mts"
  ],
  "exclude": ["node_modules"],
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node",
    "transpileOnly": true
  }
}
