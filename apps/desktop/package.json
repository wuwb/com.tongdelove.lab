{
  "productName": "my-desktop",
  "displayName": "\u81ea\u7531\u52a9\u624b",
  "name": "desktop",
  "description": "",
  "version": "0.1.0",
  "main": "./node_modules/.dev/main/index.js",
  "resources": "src/resources",
  "author": {
    "name": "WuWenbin"
  },
  "homepage": "",
  "private": true,
  "scripts": {
    "format": "prettier --write .",
    "typecheck": "concurrently -n \"node,web\" -c \"cyan,magenta\" \"npm run typecheck:node\" \"npm run typecheck:web\"",
    "typecheck:node": "tsgo --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsgo --noEmit -p tsconfig.web.json --composite false",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "downlowComponents": "pnpx @chakra-ui/cli snippet add --outdir ./src/renderer/src/components",
    "start": "electron-vite preview",
    "predev": "run-s clean:dev",
    "dev": "NODE_ENV=development electron-vite dev --watch",
    "dev:watch": "dotenv electron-vite dev -- -w",
    "compile:app": "electron-vite build",
    "compile:packageJSON": "tsx ./src/lib/electron-app/release/modules/prebuild.ts",
    "prebuild": "run-s clean:dev compile:app compile:packageJSON",
    "build": "npm run typecheck && pnpm electron-builder",
    "postinstall": "run-s prebuild install:deps",
    "install:deps": "electron-builder install-app-deps",
    "make:release": "tsx ./src/lib/electron-app/release/modules/release.ts",
    "release": "electron-builder --publish always",
    "clean:dev": "rimraf ./node_modules/.dev",
    "lint": "biome lint --no-errors-on-unmatched",
    "lint:fix": "biome lint --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.8.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@emotion/react": "^11.14.0",
    "@tauri-apps/api": "^1",
    "better-sqlite3": "11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-router-dom": "^2.1.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.3.9",
    "framer-motion": "12.23.24",
    "lucide-react": "^0.541.0",
    "next-themes": "^0.4.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "^5.5.0",
    "react-router": "^7.2.0",
    "react-router-dom": "^7.8.2",
    "simplex-noise": "4.0.3",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "@tiptap/core": "3.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.3",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/postcss": "^4.0.9",
    "@tailwindcss/vite": "^4.0.9",
    "@tauri-apps/cli": "^1",
    "@tongdelove/prettier-config": "workspace:*",
    "@tongdelove/typescript-config": "workspace:*",
    "@tongdelove/ui": "workspace:*",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/semver": "^7.5.8",
    "@vitejs/plugin-react-swc": "^3.9.0",
    "code-inspector-plugin": "^1.2.2",
    "cross-env": "^10.0.0",
    "electron": "^38.1.2",
    "electron-builder": "^26.0.12",
    "electron-extension-installer": "^2.0.0",
    "electron-vite": "^4.0.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "npm-run-all": "^4.1.5",
    "open": "^10.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "rimraf": "^6.0.1",
    "rollup-plugin-inject-process-env": "^1.3.1",
    "semver": "^7.5.4",
    "tailwindcss": "^4.0.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.9.2",
    "vite": "^7.1.6",
    "vite-tsconfig-paths": "^5.1.4",
    "concurrently": "^9.2.1"
  },
  "pnpm": {
    "onlyBuiltDependenciesFile": "./trusted-dependencies-scripts.json"
  },
  "engines": {
    "node": "22.x"
  }
}
