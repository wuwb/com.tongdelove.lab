{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "scripts",
    "src/main/**/*",
    "src/main/env.d.ts",
    "src/preload/**/*",
    "src/renderer/services/traceApi.ts",
    "src/renderer/types/*",
    "src/lib/**/*",
    "src/shared/**/*",
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/preload/preload.ts",
    "./src",
    "electron-builder.ts",
    "index.d.ts",
    "scripts"
  ],
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "moduleResolution": "bundler",
    "tsBuildInfoFile": ".tsbuildinfo/tsconfig.node.tsbuildinfo",
    "types": [
      "electron-vite/node",
      "vitest/globals"
    ],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": true,


    "importHelpers": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "isolatedModules": true,
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "paths": {
      "@logger": ["./src/main/services/LoggerService"],
      "@main/*": ["./src/main/*"],
      "@types": ["./src/renderer/src/types/index.ts"],
      "@shared/*": ["./packages/shared/*"],
      "@mcp-trace/*": ["./packages/mcp-trace/*"],
      "@modelcontextprotocol/sdk/*": ["./node_modules/@modelcontextprotocol/sdk/dist/esm/*"],
      "@/*": ["./src/*"],
      "~/*": ["./*"]
    }
  }
}
