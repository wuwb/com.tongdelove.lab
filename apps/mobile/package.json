{
  "name": "@tongdelove/expo",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "clean": "git clean -xdf .expo .turbo node_modules",
    "dev": "expo start",
    "dev:android": "expo start --android",
    "dev:ios": "expo start --ios",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "typecheck": "tsc --noEmit",
    "prettier": "prettier --write --cache .",
    "prettier-diff": "git diff --name-only | grep '^clients/web/' | sed 's|^clients/web/||' | xargs prettier --write",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "start": "next dev",
    "android-go": "expo start --android",
    "ios-go": "expo start --ios",
    "web-go": "expo start --web",
    "build": "next build",
    "reset-project": "node ./scripts/reset-project.js",
    "lint": "expo lint",
    "web": "EXPO_NO_METRO_WORKSPACE_ROOT=1 expo start --web",
    "android": "EXPO_NO_METRO_WORKSPACE_ROOT=1 expo run:android",
    "ios": "EXPO_NO_METRO_WORKSPACE_ROOT=1 expo run:ios --device"
  },
  "dependencies": {
    "@expo/html-elements": "^0.11.2",
    "@expo/metro-config": "~0.20.0",
    "@expo/metro-runtime": "~5.0.4",
    "@expo/vector-icons": "^14.1.0",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@sentry/react-native": "^6.10.0",
    "@shopify/flash-list": "1.7.6",
    "@tanstack/react-query": "^4.36.1",
    "@trpc/client": "^10.45.2",
    "@trpc/next": "^10.45.2",
    "@trpc/react-query": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "expo": "~53.0.9",
    "expo-asset": "~11.1.5",
    "expo-blur": "~14.1.4",
    "expo-constants": "~17.1.6",
    "expo-dev-client": "~5.1.8",
    "expo-drizzle-studio-plugin": "0.1.2",
    "expo-file-system": "~18.1.10",
    "expo-font": "~13.3.1",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.1.7",
    "expo-linear-gradient": "~14.1.4",
    "expo-linking": "~7.1.5",
    "expo-router": "~5.0.6",
    "expo-splash-screen": "~0.30.8",
    "expo-sqlite": "15.2.10",
    "expo-status-bar": "~2.2.3",
    "expo-store-review": "^8.0.1",
    "expo-symbols": "~0.4.4",
    "expo-system-ui": "~5.0.7",
    "expo-updates": "~0.28.13",
    "expo-web-browser": "~14.1.6",
    "nativewind": "~4.0.36",
    "next": "~14.0.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.2",
    "react-native-css-interop": "~0.0.34",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-iap": "^12.16.2",
    "react-native-permissions": "5.2.6",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.10.0",
    "react-native-web": "~0.20.0",
    "react-native-webview": "13.13.5",
    "superjson": "^2.2.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.24.4",
    "@babel/runtime": "7.26.10",
    "@craftzdog/react-native-buffer": "^6.0.5",
    "@expo/cli": "0.22.24",
    "@expo/next-adapter": "^6.0.0",
    "@tongdelove/eslint-config": "workspace:*",
    "@tongdelove/prettier-config": "workspace:*",
    "@tongdelove/tailwind-config": "workspace:*",
    "@tongdelove/typescript-config": "workspace:*",
    "@types/babel__core": "^7.20.5",
    "@types/react": "~19.0.10",
    "babel-plugin-inline-import": "^3.0.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~9.2.0",
    "tailwindcss": "^3.4.3",
    "typescript": "~5.8.3"
  }
}
