{
  "cli": {
    "version": ">= 16.3.0",
    "appVersionSource": "local"
  },
  "build": {
    "base": {
      "node": "18.16.1",
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "API_URL": "",
        "WS_URL": "",
        "EXPO_UPDATE_URL": "",
        "GROWTH_BOOK_KEY": ""
      },
      "ios": {
        "image": "macos-sonoma-14.6-xcode-16.1",
        "credentialsSource": "remote",
        "enterpriseProvisioning": "adhoc",
        "simulator": true
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "extends": "base"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./android/app/googleServiceAccount.json"
      }
    }
  }
}
