    "prettier-plugin-packagejson": "^2.4.10",
    "redux-logger": "^3.0.6",
    "typescript": "^5.8.2",
    "umi-presets-pro": "^2.0.3",
    "umi-serve": "^1.9.11",
    "yorkie": "^2.0.0"
  },
  "lint-staged": {
    "**/*.less": "stylelint --syntax less",
    "**/*.{js,jsx,ts,tsx}": "npm run lint-staged:js",
    "**/*.{js,jsx,tsx,ts,less,md,json}": [
