{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        "next-env.d.ts",
        ".expo/**",
        ".output/**",
        ".vercel/output/**"
      ]
    },
    "build-request": {
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "../../openapi/**",
        "!_*"
      ],
      "dependsOn": [
        "^build-request"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "prepare": {
      "dependsOn": [
        "^prepare"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },

    "topo": {
      "dependsOn": [
        "^topo"
      ]
    },
    "format": {
      "outputs": [
        "node_modules/.cache/.prettiercache"
      ]
    },
    "lint": {
      "dependsOn": [
        "^topo"
      ],
      "outputs": [
        "node_modules/.cache/.eslintcache"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^topo"
      ],
      "outputs": [
        "node_modules/.cache/tsbuildinfo.json"
      ]
    },
    "clean": {
      "cache": false
    }
  },
  "globalDependencies": [
    "**/.env"
  ],
  "globalEnv": [
    "DATABASE_URL",
    "AUTH_DISCORD_ID",
    "AUTH_DISCORD_SECRET",
    "AUTH_REDIRECT_PROXY_URL",
    "AUTH_SECRET"
  ]
}
