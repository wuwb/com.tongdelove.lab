{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [
    "**/.env.*local"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build",
        "test"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        "next-env.d.ts",
        ".expo/**",
        ".output/**",
        ".vercel/output/**"
      ],
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "AUTH_SECRET",
        "AUTH_GITHUB_ID",
        "AUTH_GITHUB_SECRET",
        "AUTH_REDIRECT_PROXY_URL",
        "EMAIL_SERVER",
        "EMAIL_FROM",
        "NEXT_PUBLIC_LEMON_SQUEEZY_API_KEY",
        "NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN",
        "NEXT_PUBLIC_SHOPIFY_GRAPHQL_API_ENDPOINT",
        "NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN"
      ]
    },
    "build-request": {
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "../../openapi/**",
        "!_*"
      ],
      "dependsOn": [
        "^build-request"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "prepare": {
      "dependsOn": [
        "^prepare"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "topo": {
      "dependsOn": [
        "^topo"
      ]
    },
    "format": {
      "outputs": [
        "node_modules/.cache/.prettiercache"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint",
        "^topo"
      ],
      "outputs": [
        "node_modules/.cache/.eslintcache"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^topo"
      ],
      "outputs": [
        "node_modules/.cache/tsbuildinfo.json"
      ]
    },
    "clean": {
      "cache": false
    },
    "test": {
      "dependsOn": [
        "^test"
      ]
    },
    "analyze": {
      "dependsOn": [
        "^analyze"
      ]
    }
  },
  "globalEnv": []
}
