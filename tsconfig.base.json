{
  // www.typescriptlang.org/tsconfig
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // "verbatimModuleSyntax": false, // Unknown compiler option
    "useUnknownInCatchVariables": true,
    "noImplicitOverride": true,
    "skipDefaultLibCheck": true,
    "importHelpers": true,
    "noEmitHelpers": true,
    "pretty": true,
    "noEmitOnError": false,
    "noLib": false,
    "experimentalDecorators": true,
    "newLine": "lf",
    "outDir": "./dist",
    "allowUnusedLabels": true,
    "noImplicitUseStrict": false,
    "strictFunctionTypes": true,
    "lib": [
      "dom",
      "es2018",
      "esnext.array",
      "dom.iterable",
      "esnext",
      "WebWorker"
    ],
    "module": "commonjs" /* Specify module code generation: 'none', 'commonjs', 'amd', 'system', 'umd', 'es2015', 'es2020', or 'ESNext'. */,
    "target": "es2015" /* Specify ECMAScript target version: 'ES3' (default), 'ES5', 'ES2015', 'ES2016', 'ES2017', 'ES2018', 'ES2019', 'ES2020', or 'ESNEXT'. */,
    "jsx": "react-jsx",
    "moduleResolution": "node", // 指定使用哪种模块解析策略，默认为 Classic
    "resolveJsonModule": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "strict": true,
    "alwaysStrict": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "allowUnreachableCode": false,
    "noFallthroughCasesInSwitch": true,
    "strictBindCallApply": true,
    // "declarationDir": "dist/types", // .d.ts 类型文件的输出目录，默认为 outDir 目录
    // "declaration": true,
    // "composite": false,
    "sourceMap": true,
    "esModuleInterop": true, // 通过为导入内容创建命名空间，实现 CommonJS 和 ES 模块之间的互操作性
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "skipLibCheck": true, // 跳过导入第三方 lib 声明文件的类型检查，默认为 true
    "forceConsistentCasingInFileNames": true, // 强制在文件名中使用一致的大小写，默认为 true
    "noEmit": true,
    "isolatedModules": true,
    "incremental": true,
    "strictPropertyInitialization": false,
    "emitDecoratorMetadata": true,
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "scripts",
    "**/.*/"
  ]
}
