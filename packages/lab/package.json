{
  "name": "lab",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "license": "ISC",
  "homepage": "/dashboard",
  "scripts": {
    "dev": "next",
    "build": "next build",
    "start": "next start",
    "build-stats": "cross-env ANALYZE=true npm run build",
    "build-prod": "run-s clean build export",
    "pm2-start": "pm2 start npm --name \"lab\" -- start",
    "export": "next build && next export",
    "lint": "next lint",
    "lint-fix": "next lint --fix",
    "-------------------------------- LINT ----": "----",
    "format": "prettier --write src/**/*.ts{,x}",
    "tsc-check": "tsc -v && tsc --noEmit",
    "build-types": "tsc --noEmit --pretty",
    "lint2": "tsc --noEmit && eslint src/**/*.ts{,x}",
    "fix": "yarn lint --fix && yarn format",
    "-------------------------------- TOOL ----": "----",
    "nuke": "rimraf .next && rimraf .next && rimraf yarn.lock && rimraf node_modules && yarn",
    "clear": "rimraf .next out",
    "-------------------------------- VERSIVE ----": "----",
    "versionup": "standard-version -r patch",
    "versionup:minor": "standard-version -r minor",
    "versionup:major": "standard-version -r major",
    "versionup:init": "standard-version --first-release",
    "unprepare": "husky install",
    "serve": "serve .next/analyze"
  },
  "dependencies": {
    "@emotion/cache": "latest",
    "@emotion/react": "^11.10.0",
    "@emotion/server": "latest",
    "@emotion/styled": "^11.10.0",
    "@hookform/resolvers": "^2.9.7",
    "@mui/core": "^5.0.0-alpha.54",
    "@mui/icons-material": "^5.8.4",
    "@mui/lab": "^5.0.0-alpha.73",
    "@mui/material": "^5.4.3",
    "@mui/styles": "^5.9.3",
    "@next/bundle-analyzer": "^12.2.4",
    "@tanstack/react-query": "^4.1.0",
    "@tanstack/react-query-devtools": "^4.0.10",
    "apexcharts": "^3.35.4",
    "country-flag-icons": "^1.4.26",
    "downloadjs": "^1.4.7",
    "fetch-jsonp": "^1.1.3",
    "html-to-image": "^1.10.0",
    "lodash": "^4.17.21",
    "next": "^12.2.4",
    "next-i18next": "^11.3.0",
    "next-images": "1.8.4",
    "next-offline": "^5.0.5",
    "next-seo": "^5.5.0",
    "nextjs-progressbar": "^0.0.14",
    "react": "^17.0.2",
    "react-apexcharts": "^1.4.0",
    "react-chartist": "^0.14.4",
    "react-cookie": "^4.1.1",
    "react-custom-scrollbars-2": "^4.5.0",
    "react-dom": "^17.0.2",
    "react-helmet": "^6.1.0",
    "react-helmet-async": "^1.3.0",
    "react-hook-form": "^7.34.1",
    "react-image-lightbox": "^5.1.4",
    "react-markdown": "^8.0.3",
    "sharp": "^0.30.7",
    "swiper": "^8.1.3",
    "web-vitals": "latest",
    "yup": "^0.32.11"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^12.2.5",
    "@tailwindcss/line-clamp": "^0.4.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.3.0",
    "@testing-library/user-event": "latest",
    "@types/downloadjs": "^1.4.2",
    "@types/jest": "^28.1.6",
    "@types/lodash": "^4.14.155",
    "@types/node": "^18.7.1",
    "@types/react": "17",
    "@types/react-dom": "17",
    "@typescript-eslint/eslint-plugin": "^3.3.0",
    "@typescript-eslint/parser": "^3.3.0",
    "autoprefixer": "^10.4.8",
    "eslint": "^8.10.0",
    "eslint-config-next": "^12.2.4",
    "eslint-config-prettier": "^6.11.0",
    "eslint-config-standard": "^15.0.1",
    "eslint-config-standard-jsx": "^8.1.0",
    "eslint-plugin-import": "^2.21.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^3.1.4",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-react": "^7.30.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-standard": "^4.0.1",
    "husky": "^8.0.1",
    "jest": "^28.1.3",
    "next-compose-plugins": "^2.2.1",
    "next-transpile-modules": "^9.0.0",
    "postcss": "^8.4.16",
    "prettier": "^2.7.1",
    "prettier-plugin-tailwindcss": "^0.1.13",
    "serve": "^13.0.2",
    "tailwindcss": "^3.1.8",
    "typescript": "^4.7.4"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "eslintIgnore": [
    "dist/*"
  ],
  "publishConfig": {
    "access": "restricted"
  }
}
