{
  "name": "@tongdelove/design",
  "version": "0.0.1",
  "private": true,
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.tsx"
  },
  "scripts": {
    "build": "tsc",
    "build:force": "tsup",
    "build-storybook": "storybook build --output-dir build/storybook",
    "clean": "rimraf ./dist ./build ./tsconfig.tsbuildinfo ./node_modules/.cache",
    "dev": "tsup --watch",
    "fix-all-files": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs --fix",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs --cache --cache-location ../../.cache/eslint/ui-lib.eslintcache",
    "serve-storybook": "sirv build/storybook --cors --port 8888",
    "storybook": "storybook dev -p 6006",
    "test": "run-s test-unit",
    "test-unit": "echo \"No unit tests yet\"",
    "typecheck": "tsc --project ./tsconfig.json --noEmit"
  },
  "dependencies": {
    "@chakra-ui/anatomy": "^2.2.2",
    "@chakra-ui/icons": "2.0.13",
    "@chakra-ui/react": "^3.1.2",
    "@emotion/react": "11.13.3",
    "@emotion/styled": "^11.10.8",
    "clsx": "^2.1.0",
    "react-icons": "^4.10.1",
    "react-markdown": "^8.0.7",
    "react-syntax-highlighter": "^15.5.0",
    "tailwind-merge": "^2.2.2",
    "@tongdelove/utils": "workspace:^"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "7.4.6",
    "@storybook/addon-interactions": "7.4.6",
    "@storybook/addon-links": "7.4.6",
    "@storybook/blocks": "7.4.6",
    "@storybook/react": "7.4.6",
    "@storybook/react-vite": "7.4.6",
    "@storybook/testing-library": "0.2.2",
    "@tailwindcss/aspect-ratio": "0.4.2",
    "@tailwindcss/forms": "0.5.6",
    "@testing-library/dom": "9.3.3",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "14.5.1",
    "@tongdelove/eslint-config": "workspace:^",
    "@tongdelove/typescript-config": "workspace:^",
    "@types/node": "^20.12.8",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "0.34.3",
    "autoprefixer": "10.4.16",
    "eslint-plugin-tailwindcss": "3.13.0",
    "npm-run-all": "4.1.5",
    "postcss": "^8.4.38",
    "react": "^18.2.0",
    "require-from-string": "2.0.2",
    "rimraf": "5.0.5",
    "rooks": "7.14.1",
    "sirv": "2.0.3",
    "sirv-cli": "2.0.2",
    "storybook": "8.4.6",
    "tailwindcss": "^3.4.3",
    "tsup": "7.2.0",
    "typescript": "^5.4.5",
    "vite": "4.4.10",
    "vite-tsconfig-paths": "4.2.1",
    "vitest": "^1"
  },
  "peerDependencies": {
    "@emotion/react": "11.13.3",
    "@emotion/styled": "^11.10.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
