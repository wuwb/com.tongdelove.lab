{
  "extends": "@tongdelove/typescript-config/library.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@chakra-ui/styled-system": [
        "./node_modules/@chakra-ui/styled-system"
      ]
    },
    "outDir": "dist",
    "jsx": "react-jsx",
    "target": "esnext",
    "module": "esnext",
    "noEmit": false,
    "incremental": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "src",
  ],
  "exclude": [
    "node_modules",
    "**/test/*.test.ts",
    "test",
    "dist",
    "src/_stories/*",
    "src/config/*",
  ]
}
