    "@tongdelove/tailwind-config": "workspace:*",
    "@tongdelove/typescript-config": "workspace:^",
    "@types/react": "^18.3.1",
    "react": "^18.2.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "zod": "^3.23.8"
  },
  "prettier": "@tongdelove/prettier-config"
}
