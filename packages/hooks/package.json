{
  "name": "@tongdelove/hooks",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput --sourcemap",
    "prepare": "tsc",
    "lint": "pnpm lint:prettier && pnpm lint:eslint",
    "lint:eslint": "eslint . --ext .ts",
    "lint:prettier": "prettier --check \"src/**/*.ts\"",
    "prettier": "prettier --write --cache .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tongdelove/utils": "workspace:^"
  },
  "devDependencies": {
    "@tongdelove/eslint-config": "workspace:^",
    "@tongdelove/typescript-config": "workspace:^",
    "@types/react": "^19.2.7",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^18.3.1"
  }
}
