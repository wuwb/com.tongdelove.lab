{
  "name": "@tongdelove/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "license": "UNLICENSE",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf .turbo node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@tongdelove/auth": "workspace:*",
    "@tongdelove/db": "workspace:*",
    "@tongdelove/validators": "workspace:*",
    "@trpc/server": "11.0.0-rc.334",
    "superjson": "^2.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tongdelove/eslint-config": "workspace:*",
    "@tongdelove/prettier-config": "workspace:*",
    "@tongdelove/tsconfig": "workspace:*",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "prettier": "@tongdelove/prettier-config"
}
