{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "target": "ESNext",
    "lib": [
      "dom",
      "esnext"
    ],
    "module": "ES2020",
    "composite": true,
    "noEmit": false,
    "incremental": true,
    "paths": {
      "@tongdelove/core-lib/*": [
        "../../../packages/core-lib/src/*"
      ],
      "@tongdelove/core-lib": [
        "../../../packages/core-lib/src/index"
      ]
    }
  },
  "include": [
    "src",
    ".eslintrc.*",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    "**/*.js",
    "**/*.cjs",
    "**/*.mjs",
    "**/*.jsx",
    "**/*.json"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
