# https://umijs.org/docs/guides/env-variables#analyze

# 默认开启 Babel 编译缓存，值为 none 时禁用缓存。
# BABEL_CACHE=none

# 项目根目录，需要在命令行添加
# AAP_ROOT= 

# 用于分析 bundle 构成，默认关闭。
ANALYZE=none

# 自定义端口或 analyze 选项自定义配置
ANALYZE_PORT=8889

# 默认会根据 targets 配置打目标浏览器的全量补丁，设置为 none 禁用内置的补丁方案。
BABEL_POLYFILL=none

# 默认压缩 CSS 和 JS，值为 none 时不压缩，build 时有效。
COMPRESS=none

# 设置为 none 会禁用「你知道吗」提示
DID_YOU_KNOW=none

# 设置为 none 会禁用「Error Overlay」，在调试 Error Boundary 时会有用。
ERROR_OVERLAY=none

# 默认会开启保存物理日志，值为 none 时不保存，同时针对 webcontainer 场景（比如 stackbliz）暂不保存。
FS_LOGGER=none

# 设为 none 时禁用代码热更新功能。
HMR=1

HOST=0.0.0.0

# 指定端口号，默认是 8000。
PORT=8000

# 指定用于 HMR 的 socket 服务器。
# SOCKET_SERVER

# 分析 Webpack 编译时间，支持 CONSOLE 和 JSON 两种格式，默认是 CONSOLE
# SPEED_MEASURE

# UMI_ENV

# 指定 umi 命令执行时额外加载的插件的路径，使用 , 隔开
# UMI_PLUGINS

# 指定 umi 命令执行时额外加载插件集的路径，使用 , 隔开。
# UMI_PRESETS

# 开启 webpack 的物理缓存 debug 日志。
# WEBPACK_FS_CACHE_DEBUG
