{
    "moduleFileExtensions": [
        "js",
        "json",
        "ts",
        "tsx"
    ],
    "rootDir": ".",
    "testEnvironment": "node",
    "transform": {
        "^.+\\.(t|j)s$": "ts-jest"
    },
    "testRegex": "/e2e/.*\\.(e2e-test|e2e-spec).(ts)$",
    "collectCoverageFrom": [
        "src/**/*.{js,jsx,tsx,ts}",
        "!**/node_modules/**",
        "!**/vendor/**"
    ],
    "coverageReporters": [
        "json",
        "lcov"
    ],
    "moduleNameMapper": {
        "^src/(.*)$": "<rootDir>/src/$1",
        "^test/(.*)$": "<rootDir>/test/$1",
        "^src$": "<rootDir>/src",
        "^~/(.*)$": "<rootDir>/src/$1",
        "^~$": "<rootDir>/src",
        "^test$": "<rootDir>/test"
    }
}
