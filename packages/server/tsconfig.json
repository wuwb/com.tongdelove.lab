{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "allowUnreachableCode": false,
        "noFallthroughCasesInSwitch": true,
        "skipDefaultLibCheck": true,
        "importHelpers": true,
        "module": "commonjs",
        "declaration": false,
        "strictPropertyInitialization": false,
        "sourceMap": true,
        "pretty": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "target": "es2016",
        "outDir": "../../dist/server",
        "noLib": false,
        "rootDir": ".",
        "baseUrl": ".",
        "types": ["node", "reflect-metadata", "jest", "Multer"],
        // https://stackoverflow.com/questions/61687679/nest-js-build-does-does-not-generate-the-dist-folder
        "noEmit": false,
        "noEmitOnError": false,
        "noEmitHelpers": true,
        "incremental": false, // 避免打包失败
        "skipLibCheck": true,
        "lib": [
            "ES2020",
            "esnext.array",
            "esnext.asynciterable",
            "dom.iterable",
            "esnext",
            "dom"
        ],
        "jsx": "react-jsx",
        "resolveJsonModule": true,
        "allowUnusedLabels": true,
        "noImplicitUseStrict": false,
        "noImplicitAny": false,
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "noImplicitThis": true,
        "alwaysStrict": true,
        "moduleResolution": "node",
        "noUnusedParameters": false,
        "forceConsistentCasingInFileNames": true,
        "noImplicitReturns": false,
        "noUnusedLocals": false,
        "allowJs": true,
        "strict": true,
        "paths": {
            "@prisma/client": ["./node_modules/.prisma/client"],
            "@/generated/*": ["./generated/*"],
            "@/scripts/*": ["./scripts/*"],
            "@/*": ["./src/*"]
        }
    },
    "files": [],
    "include": ["src/**/*", "jest.config.js"],
    "exclude": [
        "node_modules",
        "build",
        "dist",
        "scripts",
        "src/.umi/*",
        "webpack",
        "jest"
    ]
}
