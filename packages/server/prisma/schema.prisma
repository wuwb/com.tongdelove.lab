// 支付信息
model PayInfo {
    id           String    @id @default(cuid())
    user_id      Int       @default(0) @db.Int
    pay_id       String    @db.VarChar(63) // 微信付款编号
    pay_status   Int       @default(0) @db.Int // 支付状态，0是未支付，1是已支付
    pay_at       DateTime  @db.Timestamp(6) // 微信付款时间
    pay_platform Int       @default(0) @db.Int // 订单来源，1 支付宝，2微信
    pay_type     Int       @default(0) @db.Int // 支付类型，1 在线支付
    createdAt    DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
    updatedAt    DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
    deletedAt    DateTime  @map(name: "deleted_at") @db.Timestamp(6)

    @@map(name: "pay_info")
}

// 订单
model Order {
    id               String    @id @default(cuid())
    createdAt        DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
    updatedAt        DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
    deleted_at       DateTime  @db.Timestamp(6)
    user_id          Int       @default(0) @db.Int
    order_sn         String    @db.VarChar(63) // 订单编号
    order_status     Int       @default(0) @db.Int // 订单状态
    aftersale_status Int       @default(0) @db.SmallInt // 售后状态，0是可申请，1是用户已申请，2是管理员审核通过，3是管理员退款成功，4是管理员审核拒绝，5是用户已取消
    address_id       Int       @default(0) @db.Int
    message          String    @default("") @db.VarChar(512) // 用户订单留言
    product_price    Decimal   @db.Decimal(10, 4) // 总价
    freight_price    Decimal   @db.Decimal(10, 4) // 运费
    coupon_price     Decimal   @db.Decimal(10, 4) // 优惠券
    integral_price   Decimal   @db.Decimal(10, 4) // 积分
    groupon_price    Decimal   @db.Decimal(10, 4) // 团购价
    order_price      Decimal   @db.Decimal(10, 4) // 订单费用， = goods_price + freight_price - coupon_price
    actual_price     Decimal   @db.Decimal(10, 4) // 实付费用， = order_price - integral_price

    paymentAt DateTime @map(name: "payment_at") @db.Timestamp(6) // 支付时间
    sendAt    DateTime @map(name: "send_at") @db.Timestamp(6) // 发货时间

    ship_sn      String   @db.VarChar(63) // 快递单号
    ship_channel String   @db.VarChar(63) // 快递渠道
    ship_at      DateTime @db.Timestamp(6) // 快递发货时间

    refund_amount  Decimal  @db.Decimal(10, 4) // 实际退款金额，（有可能退款金额小于实际支付金额）
    refund_type    String   @db.VarChar(63) // 退款方式
    refund_content String   @db.VarChar(255) // 退款原因
    refund_at      DateTime @db.Timestamp(6) // 退款时间
    confirm_at     DateTime @db.Timestamp(6) // 确认收货时间
    comments       Int      @default(0) @db.SmallInt // 待评价订单商品数量
    endAt          DateTime @map(name: "end_at") @db.Timestamp(6) // 完成交易时间
    closedAt       DateTime @map(name: "closed_at") @db.Timestamp(6) // 关闭时间

    customer   Customer? @relation(fields: [customerId], references: [id]) // 一个订单有一个消费者
    customerId String?

    // todo 这种模式不行，需要增加订单详情，一个订单有多个商品，每个商品的数量不一样
    discount Float? // 优惠

    orderDetail OrderDetail[] // 订单详情

    totalPrice Int? // 总价

    @@map(name: "order")
}

// 消费者，没有注册的用户也可以进行购物，
model Customer {
    id        String    @id @default(cuid())
    firstName String?
    lastName  String?
    phone     String?
    email     String?
    orders    Order[]
    address   Address[]
    addressId String?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    @@map(name: "customer")
}

model Invoice {
    id String @id @default(cuid())

    @@map(name: "invoice")
}

// 订单详情
model OrderDetail {
    id     String  @id @default(cuid())
    userId String? @map(name: "user_id")
    payId  String? @map(name: "pay_id")

    order   Order  @relation(fields: [orderId], references: [id]) // 一个订单详情有一个订单
    orderId String

    productSku   ProductSku @relation(fields: [productSkuId], references: [id]) // 商品
    productSkuId String // 商品id

    productName String    @db.VarChar(255)
    productPic  String    @db.VarChar(255)
    unitPrice   Decimal   @db.Decimal(10, 4)
    quantity    Int?      @default(0) @db.Int
    totalPrice  Decimal   @db.Decimal(10, 4)
    createdAt   DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
    updatedAt   DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)

    @@map(name: "order_detail")
}

// 淘宝原始订单
model TaobaoOrderRaw {
    id                         String   @id @db.VarChar(63) // 订单编号
    buyerName                  String   @default("") @db.VarChar(63) // 买家昵称，买家会员名
    buyerNick                  String   @default("") @db.VarChar(63) // 买家昵称，买家会员昵称
    payId                      String   @default("") @db.VarChar(63) // 付款编号，支付单号
    payDetail                  String   @default("") @db.VarChar(255) // 付款详情，支付详情
    tradePayable               Decimal  @db.Decimal(10, 2) // 买家应付货款
    postage                    Decimal  @db.Decimal(10, 2) // 买家应付邮费
    integration                Int      @db.Int // 买家支付积分
    total                      Decimal  @db.Decimal(10, 2) // 总金额
    rebateIntegration          Int      @db.Int // 返点积分
    realTotal                  Decimal  @db.Decimal(10, 2) // 买家实际支付金额
    realIntegration            Int      @db.Int // 买家实际支付积分
    status                     String   @default("") @db.VarChar(255) // 订单状态
    message                    String   @default("") @db.VarChar(255) // 买家留言
    receiver                   String   @default("") @db.VarChar(255) // 收货人姓名
    address                    String   @default("") @db.VarChar(255) // 收货地址
    deliveryMode               String   @default("") @db.VarChar(255) // 运送方式，快递
    telephone                  String   @default("") @db.VarChar(255) // 联系电话
    cellphone                  String   @default("") @db.VarChar(255) // 联系手机
    virtualNumberExpirationAt  DateTime // 虚拟号码过期时间
    orderCreatedAt             DateTime // 订单创建时间
    payAt                      DateTime // 订单付款时间
    goodsTitle                 String   @default("") @db.VarChar(255) // 商品标题
    goodsType                  Int      @db.Int // 宝贝种类，1是普通商品，2是拍卖商品
    deliveryOrder              String   @default("") @db.VarChar(255) // 物流单号
    deliveryCompany            String   @default("") @db.VarChar(255) // 物流公司
    orderNote                  String   @default("") @db.VarChar(255) // 订单备注
    goodsCount                 Int      @default(0) @db.Int // 宝贝总数
    shopId                     String   @default("") @db.VarChar(255) // 店铺ID
    shopName                   String   @default("") @db.VarChar(255) // 店铺名称
    closedReason               String   @default("") @db.VarChar(255) // 订单关闭原因
    sellerSerivce              Int      @default(0) @db.Int // 卖家服务
    buyerService               Int      @default(0) @db.Int // 买家服务
    invoiceTitle               String   @default("") @db.VarChar(255) // 发票抬头
    isCellphoneOrder           String   @default("") @db.VarChar(255) // 是否手机订单
    stagingOrderInfo           String   @default("") @db.VarChar(255) // 分阶段订单信息
    privilegeDownPaymentOderId Int      @default(0) @db.Int // 特权订金订单ID
    isUploadContractPicture    Int      @default(0) @db.Int // 是否上传合同图片
    isUploadInvoicePicture     Int      @default(0) @db.Int // 是否上传小票
    isPayForAnother            Int      @default(0) @db.Int // 是否代付
    downPaymentRank            Int      @default(0) @db.Int // 订金排名
    modifiedSku                String   @default("") // 修改后的 sku
    modifiedAddress            String   @default("") // 修改后的收货地址
    exceptionMessage           String   @default("") // 异常信息
    tmallCouponDeduction       Int      @default(0) @db.Int // 天猫卡券抵扣
    integrationDeduction       Int      @default(0) @db.Int // 积分宝抵扣
    isO2OOrder                 Int      @default(0) @db.Int // 是否 O2O 交易
    newRetailTradeType         String   @default("") @db.VarChar(255) // 新零售交易类型，电商订单
    newRetailGuideShopName     String   @default("") @db.VarChar(255) // 新零售导购店名
    newRetailGuideShopId       String   @default("") @db.VarChar(255) // 新零售导购店ID
    newRetailDeliverShopName   String   @default("") @db.VarChar(255) // 新零售发货店名
    newRetailDeliverShopId     String   @default("") @db.VarChar(255) // 新零售发货店ID
    refundAmount               Decimal  @db.Decimal(10, 2) // 退款金额
    appointmentShop            String   @default("") @db.VarChar(255) // 预约店铺
    confirmReceiptAt           DateTime // 确认收货时间
    remitNum                   Decimal  @db.Decimal(10, 2) // 打款商家金额
    personalRedEnvelope        String   @default("") @db.VarChar(255) // 含应开票给个人的个人红包
    isCreditBuy                Int      @default(0) @db.Int // 是否是信用购
    experienceEndAt            DateTime // 体验期结束时间
    topNGift                   String   @default("") @db.VarChar(255) // 前 N 有礼
    deliveryType               String   @default("") @db.VarChar(255) // 配送类型
    liveCashbackStatus         String   @default("") @db.VarChar(255) // 直播返现状态
    cashbackAmount             Int      @default(0) @db.Int // 返现金额
    slowDeliveryCompensate     Int      @default(0) @db.Int // 延迟发货自动赔付金额
    newRetailDealShopName      String   @default("") // 新零售成交门店昵称
    newRetailDealShopId        String   @default("") // 新零售成交门店ID
    newRetailDealDealerId      String   @default("") // 新零售成交经销商ID
    isPresell                  Int      @default(0) @db.Int // 是否预售
    deliveryAt                 DateTime // 发货时间
    comment                    String   @default("") @db.VarChar(255) // 商家备忘
    masterOrderId              String   @default("") @db.VarChar(255) // 主订单编号

    @@map(name: "taobao_order_raw")
}

// 品牌
model Brand {
    id          String    @id @default(cuid())
    createdAt   DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
    updatedAt   DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
    deleted_at  DateTime  @db.Timestamp(6)
    title       String    @default("") @db.VarChar(255)
    description String    @default("") @db.VarChar(255)
    pictures    String    @default("") @db.VarChar(255)
    sort_order  Int       @default(50) @db.Int
    floor_price Decimal   @default(0.0000) @db.Decimal(10, 4)

    @@map(name: "brand")
}

// 地址
model Address {
    id         String    @id @default(cuid())
    createdAt  DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
    updatedAt  DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
    deletedAt  DateTime  @map(name: "deleted_at") @db.Timestamp(6)
    name       String    @default("") @db.VarChar(63) // 收货人名称
    userId     String    @map(name: "user_id") // 用户id
    conuntry   String    @db.VarChar(63) // 国家
    province   String    @db.VarChar(63) // 省，美国的州
    city       String    @db.VarChar(63) // 市，美国的城市
    county     String    @db.VarChar(63) // 区县
    street     String    @db.VarChar(63) // 街道
    detail     String    @db.VarChar(127) // 详细地址
    address_1  String?
    address_2  String?
    areaCode   String    @map(name: "area_code") @db.VarChar(6) // 区域编码
    postcode   String    @db.VarChar(6) // 邮政邮编
    zip        Int?
    mobile     String    @db.VarChar(20) // 电话
    isDefault  Int       @default(0) @map(name: "is_default") @db.TinyInt // 是否默认地址
    customer   Customer  @relation(fields: [customerId], references: [id])
    customerId String    @map(name: "customer_id")

    @@map(name: "address")
}

// 购物车
model Cart {
    id             String  @id @default(cuid())
    userId         String  @map(name: "user_id") // 用户 id
    productId      String  @map(name: "product_id") // 商品 id
    productSn      String  @map(name: "product_sn") @db.VarChar(63) // 商品编号
    productName    String  @map(name: "product_name") @db.VarChar(127) // 商品名称
    price          Decimal @default(0.0000) @db.Decimal(10, 4) // 商品价格
    number         Int     @default(0) @db.SmallInt // 商品数量
    specifications String  @db.VarChar(1023)
    checked        Int     @default(1) @db.TinyInt // 是否选中
    pictures       String  @db.VarChar(255)

    @@map(name: "cart")
}

// 售后
model Aftersale {
    id          String    @id @default(cuid())
    createdAt   DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
    updatedAt   DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
    deleted_at  DateTime  @db.Timestamp(6)
    aftersal_sn String    @default("") @db.VarChar(63)
    order_id    Int       @db.Int
    user_id     Int       @db.Int
    type        Int       @default(0) @db.SmallInt // 售后类型，0是未收货退款，1是已收货（无需退货）退款，2用户退货退款
    reason      String    @default("") @db.VarChar(31) // 退款原因
    amount      Decimal   @db.Decimal(10, 4) // 退款金额
    pictures    String    @db.VarChar(255) // 退款图片凭证图片链接数组
    comment     String    @db.VarChar(255) // 退款说明
    status      Int       @default(0) @db.SmallInt // 状态，售后状态，0是可申请，1是用户已申请，2是管理员审核通过，3是管理员退款成功，4是管理员审核拒绝，5是用户已取消
    handle_at   DateTime  @db.Timestamp(6)

    @@map(name: "aftersale")
}

// -------------------------------------------------

// 广告
model Ad {
    id        String    @id @default(cuid())
    createdAt DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
    updatedAt DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
    deletedAt DateTime? @map(name: "deleted_at") @db.Timestamp(6)
    title     String    @default("") @db.VarChar(63)
    link      String    @default("") @db.VarChar(255)
    position  String    @default("1") @db.VarChar(100) // 广告位置：1 是首页
    content   String    @default("") @db.VarChar(255)
