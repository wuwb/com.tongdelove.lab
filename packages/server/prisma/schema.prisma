enum SourceEnum {
    yuanjisong
    oschina
    codemart
    a5
    taskcity
    shixian
    mayigeek
    rrkf
}

model SubscribesWebhook {
    id           String     @id @default(cuid())
    webhook      String     @db.VarChar(255)
    secret       String     @db.VarChar(255)
    webhookType  String     @map(name: "webhook_type") @db.VarChar(255) // wechat feishu dingding
    remindSource SourceEnum @map(name: "remind_source") // a5/rrkf...
