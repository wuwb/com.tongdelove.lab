// 开始

// ----------------------------------------------
// e-commerce

// 产品
model Product {
    id         String       @id @default(cuid())
    productSku ProductSku[]

    createdAt     DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
    updatedAt     DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
    deletedAt     DateTime  @map(name: "deleted_at") @db.Timestamp(6)
    deleted       Boolean   @default(false) @db.TinyInt()
    slug          String    @db.VarChar(100)
    title         String?   @default("") @db.VarChar(100) // 标题
    subTitle      String    @default("") @map(name: "sub_title") @db.VarChar(100) // 副标题
    description   String?   @default("") @db.VarChar(255) // 描述
    code          String    @db.VarChar(63) // 商品编码
    flag          Int       @db.Int // 二进制打标
    brand_id      Int       @default(0) @db.Int
    category_id   Int       @default(0) @db.Int // 分类
    custom_id     Int       @db.Int // 关联其他自定义系统的数据
    summary       String    @default("") @db.VarChar(255) // 商品简介
    content       String    @db.Text // 商品详情，富文本测试
    is_on_sale    Int       @default(1) @db.TinyInt // 是否上架
    sort_order    Int       @default(100) @db.SmallInt // 排序
    image         String    @db.VarChar(255) // 主图片
    pic_url       String    @default("") @db.VarChar(255) // 图片，json 格式，可扩展
    share_url     String    @default("") @db.VarChar(255) // 分享链接
    is_new        Int       @default(0) @db.TinyInt // 是否新品
    is_hot        Int       @default(0) @db.TinyInt // 是否人气
    unit          String    @default("件") @db.VarChar(31) // 单位
    counter_price Decimal   @default(0.0000) @db.Decimal(10, 4) // 专柜价格
    retail_price  Decimal   @default(0.0000) @db.Decimal(10, 4) // 零售价格
    price         Decimal   @db.Decimal(10, 4)
    sku           String    @db.VarChar(100)
    published     Boolean   @default(false) @db.TinyInt()
    published_at  DateTime  @db.Timestamp(6)
    biz_type      Int       @db.Int

    @@map(name: "product")
}

model ProductHistory {
    id String @id @default(cuid())

    @@map(name: "product_history")
}

model ProductSnapshot {
    id String @id @default(cuid())

    @@map(name: "product_snapshot")
}

model ProductCategory {
    id          String @id @default(cuid())
    type        Int    @default(0) @db.Int // 类型，默认为 0 是产品分类，1 是文章分类
    title       String @db.VarChar(63)
    keywords    String @default("") @db.VarChar(1023)
    description String @default("") @db.VarChar(255)
    pid         Int    @db.Int
    status      Int    @default(1) @db.Int // 状态 1 启用，0禁用
    icons       String @default("") @db.VarChar(255)
    picture     String @default("") @db.VarChar(255)
    level       String @default("") @db.VarChar(255)
    sort_order  Int    @default(50) @db.Int

    @@map(name: "product_category")
}

// 收藏
model Collect {
    id        String    @id @default(cuid())
    createdAt DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
    updatedAt DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
    deletedAt DateTime  @map(name: "deleted_at") @db.Timestamp(6)
    user_id   Int       @default(0) @db.Int
    value_id  Int       @default(0) @db.Int
    type      Int       @default(0) @db.Int

    @@map(name: "collect")
}

model ProductImage {
    id String @id @default(cuid())

    @@map(name: "product_image")
}

model ProductAttrKey {
    id         String @id @default(cuid())
    product_id Int    @default(0) @db.Int
    title      String @db.VarChar(255) // 商品参数名称

    @@map("product_attr_key")
}

model ProductAttrValue {
    id          String    @id @default(cuid())
    createdAt   DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
    updatedAt   DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
    deleted_at  DateTime  @db.Timestamp(6)
    attr_key_id Int       @default(0) @db.Int
    product_id  Int       @default(0) @db.Int
    symbol      Int       @db.Int // '属性编码'
    value       String    @db.VarChar(255) // 商品参数值

    @@map(name: "product_attr_value")
}

model ProductSku {
    id        String  @id @default(cuid())
    product   Product @relation(fields: [productId], references: [id]) // 一个订单详情有一个订单
    productId String  @map(name: "product_id")

    orderDetail OrderDetail[]

    attr_symbol_path String  @db.VarChar(255)
    price            Decimal @default(0.0000) @db.Decimal(10, 4)
    stock            Int     @db.Int

    @@map(name: "product_sku")
}

