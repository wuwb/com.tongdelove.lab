// 自热餐盒
model SelfHeatingBO {
    id                   String    @id @default(cuid())
    createdAt            DateTime? @default(now()) @map(name: "created_at") @db.Timestamp(6)
    updatedAt            DateTime  @default(now()) @updatedAt @map(name: "updated_at") @db.Timestamp(6)
    innerCode            String    @unique @map(name: "inner_code") @db.VarChar(255) // 内部编码
    type                 Int       @db.Int // 类型，1表示长方形，2表示正方形，3表示圆形，4表示其他
