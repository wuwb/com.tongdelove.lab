    innerBoxType         Int       @map(name: "inner_box_type") @db.Int // 内盒类型,1 通各自，2分隔，3...
    materialType         Int       @map(name: "material_type") @db.Int // 材质类型, 1 塑料，2 铝箔
    color                Int       @db.Int // 颜色 1 红色 2 红白 3 橙色 4 黑色
    outBoxCapacity       Int       @map(name: "out_box_capacity") @db.Int // 外盒容量
    innerBoxCapacity     Int       @map(name: "inner_box_capacity") @db.Int // 内盒容量
    innerBoxCapacityLine Int       @map(name: "inner_box_capacity_line") @db.Int // 内盒容量
    innerBoxCapacity2    Int       @map(name: "inner_box_capacity2") @db.Int // 内盒容量
    innerBoxCapacity3    Int       @map(name: "inner_box_capacity3") @db.Int // 内盒容量
    innerBoxCapacity4    Int       @map(name: "inner_box_capacity4") @db.Int // 内盒容量
    outBoxSize           Int       @map(name: "out_box_size") @db.Int // 外盒尺寸
    innerBoxSize         Int       @map(name: "inner_box_size") @db.Int // 内盒尺寸
    outBoxSizeX          Int       @map(name: "out_box_size_x") @db.Int // 外盒尺寸x
    innerBoxSizeX        Int       @map(name: "inner_box_size_x") @db.Int // 内盒尺寸x
    outBoxSizeY          Int       @map(name: "out_box_size_y") @db.Int // 外盒尺寸y
    innerBoxSizeY        Int       @map(name: "inner_box_size_y") @db.Int // 内盒尺寸y
    outBoxSizeZ          Int       @map(name: "out_box_size_z") @db.Int // 外盒尺寸z
    innerBoxSizeZ        Int       @map(name: "inner_box_size_z") @db.Int // 内盒尺寸z
    lidWeight            Int       @map(name: "lid_weights") @db.Int // 封盖重量
    bottomWeight         Int       @map(name: "bottom_weight") @db.Int // 底座重量
    innerWeight          Int       @map(name: "inner_weight") @db.Int // 内盒重量
    cost                 Int       @db.Int // 成本

    @@map(name: "self_heating_bo")
}

