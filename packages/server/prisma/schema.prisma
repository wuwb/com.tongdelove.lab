model FreelancerTask {
    id           String     @id @default(cuid())
    source       SourceEnum
    sourceId     String     @map(name: "source_id") @db.VarChar(255)
    title        String     @db.VarChar(255)
    desc         String     @db.Text
    minPrice     Decimal    @default(0) @db.Decimal(10, 0)
    maxPrice     Decimal    @default(0) @db.Decimal(10, 0)
    fixedPrice   String     @map(name: "fixed_price") @db.VarChar(255)
    bargain      Boolean    @default(false) @db.TinyInt
    cycle        Int        @default(0) @db.Int
    cycleName    String     @default("天") @map(name: "cycle_name") @db.VarChar(255)
    date         DateTime   @db.Timestamp(6)
    url          String     @db.VarChar(255)
    applyCount   Int        @default(0) @map(name: "apply_count") @db.Int
    visitCount   Int        @default(0) @map(name: "visit_count") @db.Int
    status       String     @default("") @db.VarChar(255)
    auditStatus  Int        @default(0) @map(name: "audit_status") @db.Int
    auditReason  String     @default("") @map(name: "audit_reason") @db.VarChar(255)
    auditAt      DateTime   @map(name: "audit_at") @db.Timestamp(6)
    handleStatus Int        @default(0) @db.Int
    handleAt     DateTime   @map(name: "handle_at") @db.Timestamp(6)
    userId       String     @map(name: "user_id")
    userName     String     @default("") @map(name: "user_name") @db.VarChar(255)
    userUrl      String     @default("") @map(name: "user_url") @db.VarChar(255)
    type         Int        @default(0) @db.Int
    application  Int        @default(0) @db.Int // 应用类型
    tags         String     @default("") @db.VarChar(255)
    createdAt    DateTime   @default(now()) @map(name: "created_at") @db.Timestamp(6)
    updatedAt    DateTime   @updatedAt @map(name: "updated_at") @db.Timestamp(6)

    @@unique([source, title])
    @@map(name: "freelancer_task")
}

model FreeProject {
    id String @id @default(cuid())

    title   String @map(name: "webhook") @db.VarChar(255)
    content String @map(name: "content") @db.Text

    price    String @map(name: "price") @db.VarChar(255)
    duration Int    @db.Int

    time     DateTime @db.Timestamp(6)
    origin   String   @map(name: "origin") @db.VarChar(255)
    url      String   @map(name: "url") @db.VarChar(255)
    originId String?  @map(name: "origin_id") @db.VarChar(255)

    status String? // 状态是否还在招募

    applyCount Int? @default(0) @map(name: "apply_count") @db.Int
    visitCount Int? @default(0) @map(name: "visit_count") @db.Int

    developerType Int?    @map(name: "developer_type") @db.Int // 二次开发PERSONAL、全新开发、产品优化
    specificRole  Int?    @map(name: "specific_role") @db.Int // 招募对象
    type          String? @db.VarChar(255) // 类型：web 网站、APP 开发、小程序等

    bargain Boolean? @db.TinyInt // 是否可以议价

    @@unique([origin, originId])
    @@map(name: "free_project")
}

