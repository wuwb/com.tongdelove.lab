{
  "name": "@tongdelove/api-gateway",
  "version": "1.2.3",
  "private": true,
  "module": "dist/index.esm.js",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "UNLICENSE",
  "homepage": "https://github.com/belgattitude/nextjs-monorepo-example",
  "repository": {
    "type": "git",
    "url": "https://github.com/belgattitude/nextjs-monorepo-example",
    "directory": "packages/api-gateway"
  },
  "scripts": {
    "build": "echo \"Unrequired and disabled when using tsonfig paths aliases, run 'build:force' to test a build.\"",
    "build:force": "tsup",
    "dev": "tsup --watch",
    "codegen": "rimraf .mesh && mesh build --throwOnInvalidConfig=true",
    "clean": "rimraf ./dist ./coverage ./tsconfig.tsbuildinfo",
    "fix-all-files": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs --fix",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs --cache --cache-location ../../.cache/eslint/api-gateway.eslintcache",
    "typecheck": "tsc --project ./tsconfig.json --noEmit"
  },
  "dependencies": {
    "@graphql-mesh/cli": "^0.88.5",
    "@graphql-mesh/openapi": "^0.97.5",
    "@graphql-mesh/runtime": "^0.97.4"
  },
  "devDependencies": {
    "@tongdelove/eslint-config-base": "workspace:^",
    "@types/node": "^20.12.8",
    "cross-env": "7.0.3",
    "eslint": "^8.56.0",
    "graphql": "16.8.1",
    "npm-run-all": "4.1.5",
    "prettier": "^3.2.5",
    "rimraf": "5.0.5",
    "tsup": "7.2.0",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "graphql": "^16.6.0"
  }
}
