    "snyk": "^1.266.0",
    "nanoid": "^2.0.0",
    "xml2js": "^0.4.19"
  },
  "devDependencies": {
    "@nestjs/testing": "6.2.2",
    "@types/express": "^4.17.17",
    "@types/node": "^20.12.8",
    "@types/supertest": "2.0.7",
    "nodemon": "1.19.0",
    "supertest": "4.0.2",
    "ts-loader": "6.0.1",
    "tsconfig-paths": "3.8.0",
    "@nestjs/common": "^5.5.0",
    "@nestjs/core": "^5.5.0",
