    "prettier-plugin-packagejson": "^2.4.10",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "prisma": "^7.4.0",
    "prisma-json-types-generator": "^3.0.3",
    "rimraf": "^6.0.1",
    "shell-quote": "1.8.1",
    "syncpack": "^12.4.0",
