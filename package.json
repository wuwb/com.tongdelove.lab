    "debug": "^4.3.4",
    "eslint": "^9.39.1",
    "getenv": "^1.0.0",
    "globals": "^15.15.0",
    "husky": "^9.0.10",
    "inquirer": "^8",
    "is-ci": "3.0.1",
    "lint-staged": "^15.2.2",
    "metro": "0.82.4",
    "metro-cache": "0.82.4",
