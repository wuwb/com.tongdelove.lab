{
  "name": "lab.printlake.com",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "private": true,
  "type": "module",
  "author": {
    "name": "WuWenbin",
    "email": "541330190@qq.com",
    "url": "https://github.com/wuwb"
  },
  "license": "ISC",
  "homepage": "https://github.com/wuwb",
  "repository": "wuwb/com.tongdelove.lab",
  "scripts": {
    "preinstall": "pnpm db:generate",
    "db:generate": "prisma generate && pnpm run --filter",
    "dev": "pnpm run --parallel dev",
    "build:server": "pnpm --filter server build  @wu/schema build",
    "db:migrate:create": "prisma migrate dev --create-only",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "pnpm lint:prettier && pnpm lint:eslint",
    "lint:eslint": "eslint . --ext .ts",
    "lint:prettier": "prettier --check \"src/**/*.ts\"",
    "db:setup": "snaplet setup",
    "db:seed": "prisma migrate dev && snaplet snapshot restore --no-reset --no-schema",
    "build:web": "pnpm --filter web build",
    "start:server": "pnpm --filter server start:prod",
    "start:web": "pnpm --filter web start",
    "dev:design": "pnpm --filter design run dev",
    "deploy": "rsync -az --del ./packages/server/dist ubuntu@118.24.105.97:~/api.tongdelove.com/packages/server/dist",
    "prepare": "husky install",
    "commit": "git-cz",
    "format": "prettier --write \"**/*.{js,cjs,mjs,ts,tsx,md,json}\" --ignore-path .gitignore",
    "with-env": "dotenv -e .env --",
    "check:git-pristine": "./scripts/check-git-pristine.sh",
    "clean:global-cache": "rimraf ./.cache",
    "clean:turbo": "rimraf --glob '**/.turbo'",
    "deps:check": "npx npm-check-updates@latest --configFileName ncurc.yml --workspaces --root --mergeConfig",
    "deps:update": "npx npm-check-updates@latest --configFileName ncurc.yml -u --workspaces --root --mergeConfig",
    "install:playwright": "playwright install"
  },
  "prisma": {
    "schema": "prisma/prisma/schema.prisma"
  },
  "dependencies": {
    "cross-env": "7.0.3",
    "inquirer": "^8",
    "@prisma/client": "^5.8.0"
  },
  "devDependencies": {
    "prisma-json-types-generator": "^3.0.3",
    "prettier": "3.0.3",
    "prisma": "5.6.0",
    "@changesets/changelog-github": "0.4.8",
    "@changesets/cli": "2.26.2",
    "@commitlint/cli": "18.6.0",
    "@commitlint/config-conventional": "17.7.0",
    "@commitlint/cz-commitlint": "^18.4.1",
    "@eslint/js": "^8.37.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.1.0",
    "@manypkg/cli": "^0.20.0",
    "@types/inquirer": "^9",
    "@types/prettier": "2.7.3",
    "@types/shell-quote": "1.7.5",
    "commitizen": "^4.3.0",
    "conventional-changelog-cli": "^4.1.0",
    "husky": "^8.0.3",
    "is-ci": "3.0.1",
    "lint-staged": "14.0.1",
    "prettier-plugin-tailwindcss": "^0.2.4",
    "rimraf": "5.0.5",
    "shell-quote": "1.8.1",
    "typescript": "5.2.2",
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^5.33.0",
    "@typescript-eslint/parser": "^5.33.0",
    "eslint": "7.28.0",
    "snaplet": "0.77.2",
    "zod-prisma": "^0.5.4"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "engines": {
    "node": "18.x",
    "pnpm": ">=8.6.3",
    "yarn": ">=1.22.0"
  },
  "resolutions?": {
    "eslint-plugin-react-hooks": "https://github.com/vercel/next.js/issues/52365"
  },
  "resolutions": {
    "eslint-plugin-react-hooks": "4.6.0",
    "bin-wrapper": "npm:bin-wrapper-china"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": []
    },
    "overrides": {
      "canvas": "2.11.2"
    }
  }
}
