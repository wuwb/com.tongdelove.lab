  "scripts": {
    "db:generate": "prisma generate && pnpm run --filter",
    "dev": "pnpm run --parallel dev",
    "build:server": "pnpm --filter server build  @wu/schema build",
    "db:migrate:create": "prisma migrate dev --create-only",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "pnpm lint:prettier && pnpm lint:eslint",
    "lint:eslint": "ESLINT_USE_FLAT_CONFIG=true eslint .",
    "lint:prettier": "prettier --check \"apps/lab/src/**/*.ts\"",
    "build:web": "pnpm --filter web build",
    "start:server": "pnpm --filter server start:prod",
    "start:web": "pnpm --filter web start",
    "dev:design": "pnpm --filter design run dev",
    "deploy": "rsync -az --del ./packages/server/dist ubuntu@118.24.105.97:~/api.tongdelove.com/packages/server/dist",
    "commit": "git-cz",
    "format-backup": "prettier --write \"**/*.{js,cjs,mjs,ts,tsx,md,json}\" --ignore-path .gitignore",
    "with-env": "dotenv -e .env --",
    "check:git-pristine": "./scripts/check-git-pristine.sh",
    "clean:global-cache": "rimraf ./.cache",
    "clean:turbo": "rimraf --glob '**/.turbo'",
    "deps:check": "npx npm-check-updates@latest --configFileName ncurc.yml --workspaces --root --mergeConfig",
    "deps:update": "npx npm-check-updates@latest --configFileName ncurc.yml -u --workspaces --root --mergeConfig",
    "install:playwright": "playwright install",
    "commitmsg": "commitlint -E HUSKY_GIT_PARAMS",
    "build": "turbo build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "db:push": "pnpm -F db push",
    "db:studio": "pnpm -F db studio",
    "dev2": "turbo dev --parallel",
    "format": "turbo format --continue -- --cache --cache-location node_modules/.cache/.prettiercache",
    "format:fix": "turbo format --continue -- --write --cache --cache-location node_modules/.cache/.prettiercache",
    "lint2": "turbo lint --continue -- --cache --cache-location node_modules/.cache/.eslintcache",
    "lint:fix": "turbo lint --continue -- --fix --cache --cache-location node_modules/.cache/.eslintcache",
    "lint:ws": "pnpm dlx sherif@latest",
    "typecheck": "turbo typecheck",
    "ui-add": "pnpm -F ui ui-add",
    "lint:sherif": "pnpm dlx sherif@latest"
  },
  "prisma": {
    "schema": "prisma/prisma/schema.prisma"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/generator": "^7.25.0",
